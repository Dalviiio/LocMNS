{% extends 'base.html.twig' %}
{% block title %}Planning réservations — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <a href="{{ path('reservation_index') }}" class="text-gray-400 hover:text-primary transition-colors">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h1 class="text-2xl font-bold text-gray-800">Planning — {{ moisNom }}</h1>
        </div>
        <div class="flex gap-2">
            {% set moisPrec = mois - 1 %}
            {% set anneePrec = moisPrec == 0 ? annee - 1 : annee %}
            {% set moisPrecVal = moisPrec == 0 ? 12 : moisPrec %}
            <a href="{{ path('reservation_planning', {mois: moisPrecVal, annee: anneePrec}) }}"
               class="px-3 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm hover:bg-gray-200 transition-colors">
                <i class="fas fa-chevron-left"></i>
            </a>
            {% set moisSuiv = mois + 1 %}
            {% set anneeSuiv = moisSuiv == 13 ? annee + 1 : annee %}
            {% set moisSuivVal = moisSuiv == 13 ? 1 : moisSuiv %}
            <a href="{{ path('reservation_planning', {mois: moisSuivVal, annee: anneeSuiv}) }}"
               class="px-3 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm hover:bg-gray-200 transition-colors">
                <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Matériel</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Utilisateur</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Du</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Au</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Statut</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                {% for r in reservations %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-medium text-gray-800">{{ r.materiel.nom }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ r.utilisateur.nomComplet }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ r.dateDebut|date('d/m/Y') }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ r.dateFin|date('d/m/Y') }}</td>
                    <td class="px-4 py-3">
                        <span class="text-xs px-2 py-1 rounded-full {{ r.statut.badgeClass() }}">{{ r.statut.label() }}</span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-4 py-12 text-center text-gray-400">
                        <i class="fas fa-calendar text-3xl mb-2 block opacity-20"></i>
                        Aucune réservation ce mois-ci
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
