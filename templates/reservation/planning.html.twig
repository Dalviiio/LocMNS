{% extends 'base.html.twig' %}
{% block title %}Planning des réservations — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Réservations › Planning</div>

<div class="page-header">
    <div style="display:flex;align-items:center;gap:16px">
        <a href="{{ path('reservation_planning', {annee: prev.format('Y'), mois: prev.format('n')}) }}"
           class="btn btn-outline" style="padding:6px 10px"><i class="fa-solid fa-chevron-left"></i></a>
        <div>
            <div class="page-title">{{ debut|date('F Y')|capitalize }}</div>
            <div class="page-sub">{{ reservations|length }} réservation(s) ce mois</div>
        </div>
        <a href="{{ path('reservation_planning', {annee: next.format('Y'), mois: next.format('n')}) }}"
           class="btn btn-outline" style="padding:6px 10px"><i class="fa-solid fa-chevron-right"></i></a>
    </div>
    <div style="display:flex;gap:8px">
        <a href="{{ path('reservation_planning', {annee: 'now'|date('Y'), mois: 'now'|date('n')}) }}" class="btn btn-outline">Aujourd'hui</a>
        <a href="{{ path('reservation_index') }}" class="btn btn-outline"><i class="fa-solid fa-list"></i> Vue liste</a>
        <a href="{{ path('reservation_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouvelle</a>
    </div>
</div>

{# ── Calendrier ── #}
<div class="table-wrap" style="overflow:visible">
    {# Jours de la semaine #}
    <div style="display:grid;grid-template-columns:repeat(7,1fr);border-bottom:1px solid var(--border)">
        {% for jour in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
        <div style="padding:10px 0;text-align:center;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--text-3)">{{ jour }}</div>
        {% endfor %}
    </div>

    {# Grille jours #}
    <div style="display:grid;grid-template-columns:repeat(7,1fr)">
        {% set today = 'now'|date('Y-m-d') %}
        {% set annee = debut.format('Y') %}
        {% set mois  = debut.format('m') %}

        {# Cases vides avant le 1er #}
        {% for i in 1..(premier_jour - 1) %}
        <div style="min-height:100px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);background:#fafafa"></div>
        {% endfor %}

        {% for jour in 1..nb_jours %}
            {% set dateStr = annee ~ '-' ~ mois ~ '-' ~ (jour < 10 ? '0' ~ jour : jour) %}
            {% set isToday = dateStr == today %}
            {% set col = (premier_jour + jour - 2) % 7 + 1 %}
            {% set isWeekend = col == 6 or col == 7 %}
                <div style="min-height:100px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:6px;background:{{ isWeekend ? '#fafafa' : '#fff' }};position:relative">
                {# Numéro du jour #}
                <div style="display:flex;justify-content:flex-end;margin-bottom:4px">
                    <span style="width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:{{ isToday ? '700' : '400' }};background:{{ isToday ? 'var(--dark)' : 'transparent' }};color:{{ isToday ? '#fff' : (isWeekend ? 'var(--text-3)' : 'var(--text)') }};">{{ jour }}</span>
                </div>

                {# Réservations du jour — filtrées dans Twig #}
                {% for r in reservations %}
                    {% if r.dateDebut|date('Y-m-d') <= dateStr and r.dateFin|date('Y-m-d') >= dateStr %}
                        {% if r.statut.value == 'confirmee' %}
                            {% set bg = 'var(--primary)' %}{% set co = '#fff' %}
                        {% elseif r.statut.value == 'en_attente' %}
                            {% set bg = '#F0F0F0' %}{% set co = 'var(--text)' %}
                        {% else %}
                            {% set bg = '#eee' %}{% set co = '#aaa' %}
                        {% endif %}
                        <a href="{{ path('reservation_edit', {id: r.id}) }}"
                           title="{{ r.utilisateur.nomComplet }} — {{ r.materiel.nom }} ({{ r.statut.label() }})"
                           style="display:block;background:{{ bg }};color:{{ co }};border-radius:3px;padding:2px 5px;margin-bottom:2px;font-size:10px;font-weight:600;text-decoration:none;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">
                            {{ r.materiel.nom|slice(0,18) }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        {% endfor %}

        {# Cases vides après le dernier jour #}
        {% set dernierCol = (premier_jour + nb_jours - 2) % 7 + 1 %}
        {% if dernierCol < 7 %}
            {% for i in (dernierCol + 1)..7 %}
            <div style="min-height:100px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);background:#fafafa"></div>
            {% endfor %}
        {% endif %}
    </div>
</div>

{# ── Légende ── #}
<div style="display:flex;gap:16px;margin-top:12px;font-size:12px;color:var(--text-2)">
    <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:var(--primary);margin-right:5px"></span>Confirmée</span>
    <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#F0F0F0;border:1px solid #ddd;margin-right:5px"></span>En attente</span>
    <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#eee;margin-right:5px"></span>Annulée</span>
</div>

{% endblock %}
