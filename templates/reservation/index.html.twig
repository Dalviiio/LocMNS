{% extends 'base.html.twig' %}
{% block title %}Réservations — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Réservations</h1>
        <div class="flex gap-2">
            <a href="{{ path('reservation_planning') }}"
               class="flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200 transition-colors">
                <i class="fas fa-calendar-alt"></i> Planning
            </a>
            <a href="{{ path('reservation_new') }}"
               class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
                <i class="fas fa-plus"></i> Nouvelle réservation
            </a>
        </div>
    </div>

    <form method="get" class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 mb-6 flex flex-wrap gap-3">
        <input type="text" name="search" value="{{ search }}" placeholder="Rechercher..."
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm flex-1 min-w-48 focus:outline-none focus:border-primary">
        <select name="statut" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="">Tous les statuts</option>
            {% for s in statuts %}
                <option value="{{ s.value }}" {{ statutFiltre == s.value ? 'selected' : '' }}>{{ s.label() }}</option>
            {% endfor %}
        </select>
        <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
            <i class="fas fa-search"></i>
        </button>
        <a href="{{ path('reservation_index') }}" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm hover:bg-gray-200 transition-colors">
            <i class="fas fa-times"></i>
        </a>
    </form>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Matériel</th>
                    {% if isGestionnaire %}<th class="text-left px-4 py-3 text-gray-600 font-medium">Utilisateur</th>{% endif %}
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Du</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Au</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Statut</th>
                    {% if isGestionnaire %}<th class="px-4 py-3"></th>{% endif %}
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                {% for r in reservations %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-medium text-gray-800">{{ r.materiel.nom }}</td>
                    {% if isGestionnaire %}<td class="px-4 py-3 text-gray-600">{{ r.utilisateur.nomComplet }}</td>{% endif %}
                    <td class="px-4 py-3 text-gray-600">{{ r.dateDebut|date('d/m/Y') }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ r.dateFin|date('d/m/Y') }}</td>
                    <td class="px-4 py-3">
                        <span class="text-xs px-2 py-1 rounded-full {{ r.statut.badgeClass() }}">{{ r.statut.label() }}</span>
                    </td>
                    {% if isGestionnaire %}
                    <td class="px-4 py-3">
                        <form action="{{ path('reservation_statut', {id: r.id}) }}" method="post" class="flex gap-1">
                            <input type="hidden" name="_token" value="{{ csrf_token('res_statut_' ~ r.id) }}">
                            {% if r.statut.value == 'EnAttente' %}
                            <button name="statut" value="Confirmee" class="text-xs px-2 py-1 bg-green-100 text-green-700 rounded hover:bg-green-200 transition-colors">
                                <i class="fas fa-check"></i>
                            </button>
                            <button name="statut" value="Annulee" class="text-xs px-2 py-1 bg-red-100 text-red-700 rounded hover:bg-red-200 transition-colors">
                                <i class="fas fa-times"></i>
                            </button>
                            {% endif %}
                        </form>
                    </td>
                    {% endif %}
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="px-4 py-12 text-center text-gray-400">
                        <i class="fas fa-calendar text-3xl mb-2 block opacity-20"></i>
                        Aucune réservation trouvée
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
