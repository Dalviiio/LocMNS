{% extends 'base.html.twig' %}
{% block title %}Réservations — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Réservations</div>

<div class="page-header">
    <div>
        <div class="page-title">Réservations</div>
        <div class="page-sub">Gestion des réservations de matériel</div>
    </div>
    <div style="display:flex;gap:8px">
        <a href="{{ path('reservation_planning') }}" class="btn btn-outline"><i class="fa-solid fa-calendar-days"></i> Planning</a>
        <a href="{{ path('reservation_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouvelle réservation</a>
    </div>
</div>

<form method="GET" class="table-wrap" style="overflow:visible">
    <div class="table-toolbar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" placeholder="Rechercher..." value="{{ app.request.query.get('search') ?? '' }}">
        </div>
        <div style="display:flex;gap:8px">
            <select name="statut" class="form-select-sm" onchange="this.form.submit()">
                <option value="">Tous les statuts</option>
                {% for s in statuts %}
                <option value="{{ s.value }}" {{ app.request.query.get('statut') == s.value ? 'selected' : '' }}>{{ s.label() }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-outline"><i class="fa-solid fa-filter"></i> Filtrer</button>
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>#</th><th>Utilisateur</th><th>Matériel</th><th>Date début</th><th>Date fin</th><th>Statut</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for r in reservations %}
            <tr>
                <td class="td-muted">{{ r.id }}</td>
                <td class="td-bold">{{ r.utilisateur.nomComplet }}</td>
                <td>{{ r.materiel.nom }}</td>
                <td>{{ r.dateDebut|date('d/m/Y') }}</td>
                <td>{{ r.dateFin|date('d/m/Y') }}</td>
                <td><span class="sbadge {{ r.statut.badgeClass() }}">{{ r.statut.label() }}</span></td>
                <td><div class="action-btns">
                    {% if r.statut.value == 'en_attente' %}
                    <form method="POST" action="{{ path('reservation_confirmer', {id: r.id}) }}" style="display:inline">
                        <button type="submit" class="action-btn" title="Confirmer"><i class="fa-solid fa-check"></i></button>
                    </form>
                    <form method="POST" action="{{ path('reservation_annuler', {id: r.id}) }}" style="display:inline">
                        <button type="submit" class="action-btn" title="Annuler"><i class="fa-solid fa-xmark"></i></button>
                    </form>
                    {% endif %}
                    <a href="{{ path('reservation_edit', {id: r.id}) }}" class="action-btn" title="Modifier"><i class="fa-solid fa-pen"></i></a>
                </div></td>
            </tr>
            {% else %}
            <tr><td colspan="7" style="text-align:center;padding:20px;color:#999">Aucune réservation trouvée</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <div class="table-footer">
        <span>{{ reservations|length }} résultat(s)</span>
    </div>
</form>
{% endblock %}
