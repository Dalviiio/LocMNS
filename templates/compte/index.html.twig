{% extends 'base.html.twig' %}
{% block title %}Mon compte — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Mon compte</div>

<div class="page-header">
    <div>
        <div class="page-title">{{ utilisateur.nomComplet }}</div>
        <div class="page-sub">{{ utilisateur.profil.nom }} — {{ utilisateur.email }}</div>
    </div>
</div>

<div class="form-grid-2-16 compte-wrap">

    <div class="table-wrap panel-padded">
        <div class="panel-title form-section-title-mb">Modifier mon profil</div>
        <form method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_compte') }}">
            <div class="form-col">
                <div class="form-field-sm">
                    <label class="form-label">Prénom</label>
                    <input type="text" name="prenom" class="form-control" value="{{ utilisateur.prenom }}" required>
                </div>
                <div class="form-field-sm">
                    <label class="form-label">Nom</label>
                    <input type="text" name="nom" class="form-control" value="{{ utilisateur.nom }}" required>
                </div>
                <div class="form-field-sm">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" value="{{ utilisateur.email }}" required>
                </div>
                <div class="form-field-sm">
                    <label class="form-label">Nouveau mot de passe <span class="form-label-note">(laisser vide)</span></label>
                    <input type="password" name="mot_de_passe" class="form-control" autocomplete="new-password">
                </div>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
            </div>
        </form>
    </div>

    <div class="table-wrap panel-padded">
        <div class="panel-title form-section-title-mb">Informations</div>
        <table><tbody>
            <tr><td class="td-label-wide">Profil</td><td><span class="sbadge sb-info">{{ utilisateur.profil.nom }}</span></td></tr>
            <tr><td class="td-label-wide">Membre depuis</td><td>{{ utilisateur.createdAt|date('d/m/Y') }}</td></tr>
            <tr><td class="td-label-wide">Emprunts actifs</td><td>{{ utilisateur.empruntsActifs|length }}</td></tr>
            <tr><td class="td-label-wide">Réservations</td><td>{{ utilisateur.reservations|length }}</td></tr>
        </tbody></table>

        <div class="form-actions">
            <a href="{{ path('logout') }}" class="btn btn-outline btn-full">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Se déconnecter
            </a>
        </div>
    </div>

</div>
{% endblock %}
