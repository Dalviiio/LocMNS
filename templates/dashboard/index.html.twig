{% extends 'base.html.twig' %}
{% block title %}Tableau de bord — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Tableau de bord</h1>
        <span class="text-sm text-gray-500">{{ 'now'|date('d/m/Y H:i') }}</span>
    </div>

    {# KPIs #}
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-laptop text-blue-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-800">{{ totalMateriels }}</p>
                    <p class="text-xs text-gray-500">Matériels</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-check text-green-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-800">{{ materielsDispos }}</p>
                    <p class="text-xs text-gray-500">Disponibles</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-handshake text-orange-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-800">{{ materielsEmpruntes }}</p>
                    <p class="text-xs text-gray-500">Empruntés</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-clock text-red-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold {{ retards > 0 ? 'text-red-600' : 'text-gray-800' }}">{{ retards }}</p>
                    <p class="text-xs text-gray-500">Retards</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-calendar text-purple-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold text-gray-800">{{ reservationsEnAttente }}</p>
                    <p class="text-xs text-gray-500">Réservations</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-yellow-100 rounded-lg flex items-center justify-center">
                    <i class="fas fa-tools text-yellow-600"></i>
                </div>
                <div>
                    <p class="text-2xl font-bold {{ incidents > 0 ? 'text-yellow-700' : 'text-gray-800' }}">{{ incidents }}</p>
                    <p class="text-xs text-gray-500">Incidents</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Emprunts en cours #}
        <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
                <h2 class="font-semibold text-gray-700">Emprunts en cours</h2>
                <a href="{{ path('emprunt_index') }}" class="text-primary text-sm hover:underline">Voir tout</a>
            </div>
            <div class="divide-y divide-gray-50">
                {% for emprunt in empruntsEnCours|slice(0, 8) %}
                <div class="flex items-center gap-3 px-5 py-3 hover:bg-gray-50 transition-colors">
                    <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-laptop text-orange-500 text-sm"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-800 truncate">{{ emprunt.materiel.nom }}</p>
                        <p class="text-xs text-gray-500">{{ emprunt.utilisateur.nomComplet }}</p>
                    </div>
                    <div class="text-right flex-shrink-0">
                        <p class="text-xs {{ emprunt.enRetard ? 'text-red-600 font-semibold' : 'text-gray-500' }}">
                            {{ emprunt.dateFinPrevue|date('d/m/Y') }}
                        </p>
                        {% if emprunt.enRetard %}
                            <span class="text-xs bg-red-100 text-red-700 px-1.5 py-0.5 rounded">Retard</span>
                        {% endif %}
                    </div>
                    <a href="{{ path('emprunt_show', {id: emprunt.id}) }}" class="text-gray-400 hover:text-primary ml-2">
                        <i class="fas fa-arrow-right text-xs"></i>
                    </a>
                </div>
                {% else %}
                <div class="px-5 py-8 text-center text-gray-400 text-sm">
                    <i class="fas fa-handshake text-2xl mb-2 block opacity-30"></i>
                    Aucun emprunt en cours
                </div>
                {% endfor %}
            </div>
        </div>

        {# Alertes récentes #}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
                <h2 class="font-semibold text-gray-700">Alertes récentes</h2>
                <a href="{{ path('alerte_index') }}" class="text-primary text-sm hover:underline">Voir tout</a>
            </div>
            <div class="divide-y divide-gray-50">
                {% for alerte in alertesRecentes %}
                <div class="px-5 py-3">
                    <div class="flex items-start gap-2">
                        <span class="text-xs px-2 py-0.5 rounded-full mt-0.5 {{ alerte.type.badgeClass() }}">{{ alerte.type.label() }}</span>
                    </div>
                    <p class="text-xs text-gray-600 mt-1 line-clamp-2">{{ alerte.message }}</p>
                    <p class="text-xs text-gray-400 mt-1">{{ alerte.createdAt|date('d/m/Y H:i') }}</p>
                </div>
                {% else %}
                <div class="px-5 py-8 text-center text-gray-400 text-sm">
                    <i class="fas fa-bell text-2xl mb-2 block opacity-30"></i>
                    Aucune alerte
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
