{% extends 'base.html.twig' %}
{% block title %}Dashboard — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Dashboard</div>

<!-- KPI -->
<div class="kpi-strip">
    <div class="kpi-card">
        <div class="kpi-label"><i class="fa-solid fa-box-open"></i> Matériels indisponibles</div>
        <div class="kpi-value">{{ kpi.materiels_indisponibles }}</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label"><i class="fa-solid fa-clock"></i> Retards de retour</div>
        <div class="kpi-value">{{ kpi.retards }}</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label"><i class="fa-solid fa-triangle-exclamation"></i> Incidents ouverts</div>
        <div class="kpi-value">{{ kpi.incidents }}</div>
    </div>
    <div class="kpi-card" style="border-right:none">
        <div class="kpi-label"><i class="fa-solid fa-inbox"></i> Demandes en attente</div>
        <div class="kpi-value">{{ kpi.demandes }}</div>
    </div>
</div>

<!-- ÉTAT DU STOCK -->
<div class="stock-grid">
    <div class="stock-card">
        <div class="stock-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
        <div class="stock-info">
            <div class="stock-label">Total matériels</div>
            <div class="stock-value">{{ stock.total }}</div>
            <div class="stock-sub">dans le parc</div>
        </div>
    </div>
    <div class="stock-card">
        <div class="stock-icon" style="color:#22c55e"><i class="fa-solid fa-circle-check"></i></div>
        <div class="stock-info">
            <div class="stock-label">Disponibles</div>
            <div class="stock-value" style="color:#22c55e">{{ stock.disponibles }}</div>
            <div class="stock-sub">prêts à l'emprunt</div>
        </div>
    </div>
    <div class="stock-card">
        <div class="stock-icon" style="color:#f59e0b"><i class="fa-solid fa-right-left"></i></div>
        <div class="stock-info">
            <div class="stock-label">En cours d'emprunt</div>
            <div class="stock-value" style="color:#f59e0b">{{ stock.empruntes }}</div>
            <div class="stock-sub">actuellement sortis</div>
        </div>
    </div>
</div>

<!-- CALENDRIER -->
{% set jours_semaine = ['Lu', 'Ma', 'Me', 'Je', 'Ve', 'Sa', 'Di'] %}
{% set mois_noms = ['','Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}

{# Jours avec réservation ce mois #}
{% set jours_resa = [] %}
{% for r in reservations_mois %}
    {% set d = r.dateDebut|date('j')|number_format %}
    {% if d not in jours_resa %}{% set jours_resa = jours_resa|merge([d]) %}{% endif %}
{% endfor %}

{# Semaine courante : lundi au dimanche #}
{% set today_num   = 'now'|date('j')|number_format %}
{% set today_dow   = 'now'|date('N')|number_format %}{# 1=lun … 7=dim #}
{% set week_days   = [] %}
{% for i in 0..6 %}
    {% set offset = i - (today_dow - 1) %}
    {% set day_num = today_num + offset %}
    {% set week_days = week_days|merge([day_num]) %}
{% endfor %}

<div class="cal-panel">
    <div class="cal-header">
        <div class="cal-header-left">
            <span class="cal-header-month">{{ mois_noms[cal_mois] }}</span>
            <span class="cal-header-year">{{ cal_annee }}</span>
        </div>
        <a href="{{ path('reservation_planning') }}" class="cal-header-link">Planning →</a>
    </div>

    <div class="cal-week">
        {% for i in 0..6 %}
        {% set d = week_days[i] %}
        {% set is_today = (d == today_num) %}
        {% set has_evt  = (d in jours_resa and d >= 1 and d <= 31) %}
        <div class="cal-week-day {{ has_evt ? 'has-evt' : '' }}">
            <span class="cal-week-lbl">{{ jours_semaine[i] }}</span>
            <span class="cal-week-num {{ is_today ? 'today' : '' }} {{ has_evt ? 'has-evt' : '' }}">
                {{ d > 0 ? d : '' }}
            </span>
            <span class="cal-week-dot"></span>
        </div>
        {% endfor %}
    </div>

    {% set prochaines = [] %}
    {% for r in reservations_mois %}
        {% if r.dateDebut|date('j')|number_format >= today_num and prochaines|length < 3 %}
            {% set prochaines = prochaines|merge([r]) %}
        {% endif %}
    {% endfor %}

    {% if prochaines is not empty %}
    <div class="cal-upcoming">
        {% for r in prochaines %}
        <div class="cal-upcoming-item">
            <span class="cal-upcoming-date">{{ r.dateDebut|date('d/M') }}</span>
            <div class="cal-upcoming-info">
                <div class="cal-upcoming-mat">{{ r.materiel.nom }}</div>
                <div class="cal-upcoming-user">{{ r.utilisateur.nomComplet }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <div class="cal-legend">
        <div class="cal-legend-item">
            <div class="cal-legend-dot" style="background:var(--dark)"></div>
            Aujourd'hui
        </div>
        <div class="cal-legend-item">
            <div class="cal-legend-dot" style="background:var(--primary)"></div>
            Réservation
        </div>
    </div>
</div>

<!-- NOTIFICATIONS + ACTIVITÉ -->
<div class="bottom-grid">

    <div class="panel">
        <div class="panel-title">Alertes récentes</div>
        <div class="notif-list">
            {% for alerte in alertes_recentes %}
            <div class="notif-item">
                <div class="notif-check"></div>
                <div class="notif-body">
                    <div class="notif-meta">
                        <span class="notif-badge {{ alerte.type.badgeClass() == 'sb-danger' ? 'badge-green' : (alerte.type.badgeClass() == 'sb-warning' ? 'badge-purple' : 'badge-blend') }}">
                            {{ alerte.type.label() }}
                        </span>
                        <span class="notif-time">{{ alerte.createdAt|date('d/m/Y H:i') }}</span>
                    </div>
                    <div class="notif-title">{{ alerte.message }}</div>
                    {% if alerte.emprunt %}
                        <div class="notif-text">Emprunt #{{ alerte.emprunt.id }} — {{ alerte.emprunt.materiel.nom }}</div>
                    {% endif %}
                    <div class="notif-author">{{ alerte.utilisateur.nomComplet }}</div>
                </div>
            </div>
            {% else %}
            <div style="padding:20px;text-align:center;color:#999;font-size:13px">Aucune alerte non lue</div>
            {% endfor %}
        </div>
    </div>

    <div class="panel">
        <div class="panel-title">Emprunts en cours</div>
        <div class="notif-list">
            {% for emprunt in emprunts_en_cours %}
            <div class="notif-item">
                <div class="notif-check"></div>
                <div class="notif-body">
                    <div class="notif-meta">
                        <span class="notif-badge {{ emprunt.enRetard ? 'badge-green' : 'badge-purple' }}">
                            {{ emprunt.enRetard ? 'Retard' : 'En cours' }}
                        </span>
                        <span class="notif-time">Retour prévu : {{ emprunt.dateFinPrevue|date('d/m/Y') }}</span>
                    </div>
                    <div class="notif-title">{{ emprunt.materiel.nom }}</div>
                    <div class="notif-text">Début : {{ emprunt.dateDebut|date('d/m/Y') }}</div>
                    <div class="notif-author">{{ emprunt.utilisateur.nomComplet }}</div>
                </div>
            </div>
            {% else %}
            <div style="padding:20px;text-align:center;color:#999;font-size:13px">Aucun emprunt en cours</div>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
