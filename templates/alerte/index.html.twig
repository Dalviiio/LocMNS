{% extends 'base.html.twig' %}
{% block title %}Alertes — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Alertes</div>

<div class="page-header">
    <div>
        <div class="page-title">Alertes <span style="font-size:15px;color:#999;font-weight:400">({{ count_nonlues }} non lues)</span></div>
        <div class="page-sub">Centre de notifications et alertes</div>
    </div>
    <form method="POST" action="{{ path('alerte_tout_lire') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('tout_lire') }}">
        <button type="submit" class="btn btn-outline"><i class="fa-solid fa-check-double"></i> Tout marquer comme lu</button>
    </form>
</div>

<form method="GET" class="table-wrap" style="overflow:visible">
    <div class="table-toolbar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" placeholder="Rechercher..." value="{{ app.request.query.get('search') ?? '' }}">
        </div>
        <div style="display:flex;gap:8px">
            <select name="type" class="form-select-sm" onchange="this.form.submit()">
                <option value="">Tous les types</option>
                {% for t in types %}
                <option value="{{ t.value }}" {{ app.request.query.get('type') == t.value ? 'selected' : '' }}>{{ t.label() }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-outline"><i class="fa-solid fa-filter"></i> Filtrer</button>
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>Lu</th><th>Type</th><th>Message</th><th>Utilisateur</th><th>Emprunt</th><th>Date</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for a in alertes %}
            <tr>
                <td>
                    {% if a.lu %}
                        <i class="fa-regular fa-circle" style="color:#ccc;font-size:9px"></i>
                    {% else %}
                        <i class="fa-solid fa-circle" style="color:var(--primary);font-size:9px"></i>
                    {% endif %}
                </td>
                <td><span class="sbadge {{ a.type.badgeClass() }}">{{ a.type.label() }}</span></td>
                <td>{{ a.message }}</td>
                <td class="td-bold">{{ a.utilisateur.nomComplet }}</td>
                <td class="td-muted">{{ a.emprunt ? '#' ~ a.emprunt.id : '—' }}</td>
                <td class="td-muted">{{ a.createdAt|date('d/m/Y H:i') }}</td>
                <td><div class="action-btns">
                    {% if not a.lu %}
                    <form method="POST" action="{{ path('alerte_lire', {id: a.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('lire_alerte' ~ a.id) }}">
                        <button type="submit" class="action-btn" title="Marquer comme lu"><i class="fa-solid fa-check"></i></button>
                    </form>
                    {% endif %}
                    <form method="POST" action="{{ path('alerte_delete', {id: a.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('del_alerte' ~ a.id) }}">
                        <button type="submit" class="action-btn" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
                    </form>
                </div></td>
            </tr>
            {% else %}
            <tr><td colspan="7" style="text-align:center;padding:20px;color:#999">Aucune alerte</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <div class="table-footer">
        <span>{{ alertes|length }} alerte(s)</span>
    </div>
</form>
{% endblock %}
