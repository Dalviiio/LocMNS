{% extends 'base.html.twig' %}
{% block title %}Alertes — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Alertes</h1>
        <form action="{{ path('alerte_tout_lire') }}" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('alerte_tout_lire') }}">
            <button type="submit" class="flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200 transition-colors">
                <i class="fas fa-check-double"></i> Tout marquer lu
            </button>
        </form>
    </div>

    <form method="get" class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 mb-6 flex flex-wrap gap-3">
        <input type="text" name="search" value="{{ search }}" placeholder="Rechercher..."
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm flex-1 min-w-48 focus:outline-none focus:border-primary">
        <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
            <i class="fas fa-search"></i>
        </button>
        <a href="{{ path('alerte_index') }}" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm">
            <i class="fas fa-times"></i>
        </a>
    </form>

    <div class="space-y-3">
        {% for alerte in alertes %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex items-start gap-4 {{ alerte.lu ? 'opacity-60' : '' }}">
            <div class="flex-shrink-0 mt-0.5">
                <span class="text-xs px-2 py-1 rounded-full {{ alerte.type.badgeClass() }}">{{ alerte.type.label() }}</span>
            </div>
            <div class="flex-1">
                <p class="text-sm text-gray-800">{{ alerte.message }}</p>
                <div class="flex items-center gap-3 mt-1">
                    <p class="text-xs text-gray-400">{{ alerte.createdAt|date('d/m/Y H:i') }}</p>
                    {% if isGestionnaire %}
                    <p class="text-xs text-gray-400">— {{ alerte.utilisateur.nomComplet }}</p>
                    {% endif %}
                    {% if alerte.emprunt %}
                    <a href="{{ path('emprunt_show', {id: alerte.emprunt.id}) }}" class="text-xs text-primary hover:underline">
                        Voir l'emprunt
                    </a>
                    {% endif %}
                </div>
            </div>
            {% if not alerte.lu %}
            <form action="{{ path('alerte_lire', {id: alerte.id}) }}" method="post" class="flex-shrink-0">
                <input type="hidden" name="_token" value="{{ csrf_token('alerte_lire_' ~ alerte.id) }}">
                <button type="submit" class="text-gray-400 hover:text-green-600 transition-colors" title="Marquer comme lu">
                    <i class="fas fa-check"></i>
                </button>
            </form>
            {% else %}
            <i class="fas fa-check text-green-400 flex-shrink-0"></i>
            {% endif %}
        </div>
        {% else %}
        <div class="py-16 text-center text-gray-400">
            <i class="fas fa-bell text-4xl mb-3 block opacity-20"></i>
            Aucune alerte
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
