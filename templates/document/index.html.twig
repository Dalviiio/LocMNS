{% extends 'base.html.twig' %}
{% block title %}Documents — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Documents</div>

<div class="page-header">
    <div>
        <div class="page-title">Documents</div>
        <div class="page-sub">Notices et documentations techniques</div>
    </div>
</div>

<form method="GET" class="table-wrap" style="overflow:visible">
    <div class="table-toolbar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" placeholder="Rechercher un document..." value="{{ app.request.query.get('search') ?? '' }}">
        </div>
        <div style="display:flex;gap:8px">
            <select name="type" class="form-select-sm" onchange="this.form.submit()">
                <option value="">Tous les types</option>
                <option value="notice" {{ app.request.query.get('type') == 'notice' ? 'selected' : '' }}>Notice</option>
                <option value="doc_technique" {{ app.request.query.get('type') == 'doc_technique' ? 'selected' : '' }}>Doc technique</option>
                <option value="video" {{ app.request.query.get('type') == 'video' ? 'selected' : '' }}>Vidéo</option>
            </select>
            <button type="submit" class="btn btn-outline"><i class="fa-solid fa-filter"></i> Filtrer</button>
        </div>
    </div>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Titre</th>
                <th>Matériel associé</th>
                <th>Type</th>
                <th>URL</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for doc in documents %}
            <tr>
                <td class="td-muted">{{ doc.id }}</td>
                <td class="td-bold">{{ doc.titre }}</td>
                <td><a href="{{ path('materiel_show', {id: doc.materiel.id}) }}" style="color:inherit">{{ doc.materiel.nom }}</a></td>
                <td><span class="sbadge {{ doc.type.badgeClass() }}">{{ doc.type.label() }}</span></td>
                <td class="td-muted">{{ doc.url }}</td>
                <td><div class="action-btns">
                    <a href="{{ doc.url }}" target="_blank" class="action-btn" title="Ouvrir"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
                    <a href="{{ path('materiel_show', {id: doc.materiel.id}) }}" class="action-btn" title="Voir le matériel"><i class="fa-solid fa-box"></i></a>
                </div></td>
            </tr>
            {% else %}
            <tr><td colspan="6" style="text-align:center;padding:20px;color:#999">Aucun document — ajoutez-en depuis la fiche d'un matériel</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <div class="table-footer">
        <span>{{ documents|length }} document(s)</span>
    </div>
</form>
{% endblock %}
