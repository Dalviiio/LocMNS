{% extends 'base.html.twig' %}
{% block title %}Profils & Autorisations — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Utilisateurs › Profils & Autorisations</div>

<div class="page-header">
    <div>
        <div class="page-title">Profils & Autorisations</div>
        <div class="page-sub">Gérer les accès aux catégories de matériel par profil</div>
    </div>
    <a href="{{ path('utilisateur_index') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
</div>

<div class="table-wrap table-wrap-scroll">
    <form method="POST" action="{{ path('profil_autorisations') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('save_autorisations') }}">

        <table class="profil-table">
            <thead>
                <tr>
                    <th class="th-minw-160">Catégorie</th>
                    {% for profil in profils %}
                    <th class="th-minw-130">
                        <div>{{ profil.nom }}</div>
                        <div class="profil-th-sub">{{ profil.categories|length }} cat.</div>
                    </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for cat in categories %}
                <tr>
                    <td>
                        <div class="profil-cat-name">{{ cat.nom }}</div>
                        {% if cat.description %}
                        <div class="profil-cat-desc">{{ cat.description }}</div>
                        {% endif %}
                    </td>
                    {% for profil in profils %}
                    <td class="td-center">
                        <input
                            type="checkbox"
                            name="autorisations[{{ profil.id }}][{{ cat.id }}]"
                            value="1"
                            {% if profil.categories.contains(cat) %}checked{% endif %}
                            class="profil-checkbox"
                        >
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="table-footer">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer les autorisations</button>
        </div>
    </form>
</div>

<!-- Récap par profil -->
<div class="profil-recap-grid">
    {% for profil in profils %}
    <div class="table-wrap profil-card">
        <div class="profil-card-title">{{ profil.nom }}</div>
        <div class="profil-card-desc">{{ profil.description }}</div>
        {% if profil.categories is empty %}
            <div class="profil-no-access"><i class="fa-solid fa-lock"></i> Aucun accès</div>
        {% else %}
            {% for cat in profil.categories %}
            <div class="profil-cat-item">
                <i class="fa-solid fa-circle-check profil-cat-check"></i> {{ cat.nom }}
            </div>
            {% endfor %}
        {% endif %}
    </div>
    {% endfor %}
</div>

{% endblock %}
