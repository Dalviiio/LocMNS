{% extends 'base.html.twig' %}
{% block title %}Profils & Autorisations — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Utilisateurs › Profils & Autorisations</div>

<div class="page-header">
    <div>
        <div class="page-title">Profils & Autorisations</div>
        <div class="page-sub">Gérer les accès aux catégories de matériel par profil</div>
    </div>
    <a href="{{ path('utilisateur_index') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
</div>

<div class="table-wrap" style="overflow-x:auto">
    <form method="POST" action="{{ path('profil_autorisations') }}">
        <input type="hidden" name="_token" value="{{ csrf_token('save_autorisations') }}">

        <table style="min-width:700px">
            <thead>
                <tr>
                    <th style="min-width:160px">Catégorie</th>
                    {% for profil in profils %}
                    <th style="text-align:center;min-width:130px">
                        <div>{{ profil.nom }}</div>
                        <div style="font-size:10px;font-weight:400;color:#aaa;margin-top:2px">{{ profil.categories|length }} cat.</div>
                    </th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for cat in categories %}
                <tr>
                    <td>
                        <div style="font-weight:600;font-size:13px">{{ cat.nom }}</div>
                        {% if cat.description %}
                        <div style="font-size:11px;color:#aaa">{{ cat.description }}</div>
                        {% endif %}
                    </td>
                    {% for profil in profils %}
                    <td style="text-align:center">
                        <input
                            type="checkbox"
                            name="autorisations[{{ profil.id }}][{{ cat.id }}]"
                            value="1"
                            {% if profil.categories.contains(cat) %}checked{% endif %}
                            style="width:18px;height:18px;accent-color:var(--primary);cursor:pointer"
                        >
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="table-footer">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer les autorisations</button>
        </div>
    </form>
</div>

<!-- Récap par profil -->
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-top:16px">
    {% for profil in profils %}
    <div class="table-wrap" style="padding:16px">
        <div style="font-weight:700;font-size:13px;margin-bottom:10px">{{ profil.nom }}</div>
        <div style="font-size:11px;color:#999;margin-bottom:8px">{{ profil.description }}</div>
        {% if profil.categories is empty %}
            <div style="font-size:12px;color:#FF5C2C"><i class="fa-solid fa-lock"></i> Aucun accès</div>
        {% else %}
            {% for cat in profil.categories %}
            <div style="font-size:11px;padding:3px 0;border-bottom:1px solid #F5F5F5;display:flex;align-items:center;gap:6px">
                <i class="fa-solid fa-circle-check" style="color:#22c55e;font-size:9px"></i> {{ cat.nom }}
            </div>
            {% endfor %}
        {% endif %}
    </div>
    {% endfor %}
</div>

{% endblock %}
