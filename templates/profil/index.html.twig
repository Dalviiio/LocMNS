{% extends 'base.html.twig' %}
{% block title %}Profils — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto">

    <h1 class="text-2xl font-bold text-gray-800 mb-6">Profils & autorisations</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {% for profil in profils %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <div class="flex items-center justify-between mb-4">
                <h2 class="font-semibold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-id-card text-primary"></i> {{ profil.nom }}
                </h2>
                <span class="text-xs text-gray-400">{{ profil.utilisateurs|length }} utilisateur(s)</span>
            </div>

            {% if profil.description %}
            <p class="text-sm text-gray-500 mb-4">{{ profil.description }}</p>
            {% endif %}

            <form action="{{ path('profil_categories', {id: profil.id}) }}" method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('profil_cat_' ~ profil.id) }}">

                <p class="text-xs font-medium text-gray-600 mb-2">Catégories autorisées :</p>
                <div class="space-y-1 mb-4">
                    {% for cat in categories %}
                    <label class="flex items-center gap-2 text-sm cursor-pointer">
                        <input type="checkbox" name="categories[]" value="{{ cat.id }}"
                               {{ profil.categories.contains(cat) ? 'checked' : '' }}
                               class="rounded border-gray-300 text-primary focus:ring-primary">
                        <span class="text-gray-700">{{ cat.nom }}</span>
                    </label>
                    {% endfor %}
                </div>

                <button type="submit" class="w-full py-2 bg-primary text-white text-sm rounded-lg hover:bg-orange-600 transition-colors font-medium">
                    <i class="fas fa-save mr-1"></i> Enregistrer
                </button>
            </form>
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
