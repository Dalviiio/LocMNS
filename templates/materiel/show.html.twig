{% extends 'base.html.twig' %}
{% block title %}{{ materiel.nom }} — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('materiel_index') }}" class="text-gray-400 hover:text-primary transition-colors">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-800 flex-1">{{ materiel.nom }}</h1>
        {% if isGestionnaire %}
        <a href="{{ path('materiel_edit', {id: materiel.id}) }}"
           class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
            <i class="fas fa-edit"></i> Modifier
        </a>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-info-circle text-primary"></i> Informations
            </h2>
            <dl class="space-y-3">
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">État</dt>
                    <dd><span class="text-xs px-2 py-1 rounded-full {{ materiel.etat.badgeClass() }}">{{ materiel.etat.label() }}</span></dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Catégorie</dt>
                    <dd class="text-sm font-medium text-gray-700">{{ materiel.categorie.nom }}</dd>
                </div>
                {% if materiel.numeroSerie %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">N° de série</dt>
                    <dd class="text-sm font-mono text-gray-700">{{ materiel.numeroSerie }}</dd>
                </div>
                {% endif %}
                {% if materiel.localisation %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Localisation</dt>
                    <dd class="text-sm text-gray-700">{{ materiel.localisation }}</dd>
                </div>
                {% endif %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Ajouté le</dt>
                    <dd class="text-sm text-gray-700">{{ materiel.createdAt|date('d/m/Y') }}</dd>
                </div>
            </dl>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-puzzle-piece text-primary"></i> Accessoires ({{ materiel.accessoires|length }})
            </h2>
            {% if materiel.accessoires|length %}
            <div class="space-y-2">
                {% for acc in materiel.accessoires %}
                <div class="flex items-center gap-2 text-sm">
                    <i class="fas fa-circle text-xs text-primary"></i>
                    <a href="{{ path('materiel_show', {id: acc.id}) }}" class="text-gray-700 hover:text-primary">{{ acc.nom }}</a>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <p class="text-sm text-gray-400">Aucun accessoire associé</p>
            {% endif %}
        </div>

        {% if materiel.documents|length %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 md:col-span-2">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-file-alt text-primary"></i> Documents ({{ materiel.documents|length }})
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {% for doc in materiel.documents %}
                <a href="{{ doc.url }}" target="_blank" rel="noopener"
                   class="flex items-center gap-3 p-3 border border-gray-100 rounded-lg hover:border-primary transition-colors group">
                    <i class="fas fa-file-pdf text-red-400 text-lg"></i>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-700 group-hover:text-primary truncate">{{ doc.titre }}</p>
                        <p class="text-xs text-gray-400">{{ doc.type.label() }}</p>
                    </div>
                    <i class="fas fa-external-link-alt text-gray-300 text-xs"></i>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

    </div>

    {% if isAdmin %}
    <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-xl">
        <p class="text-sm text-red-700 font-medium mb-3">Zone danger</p>
        <form action="{{ path('materiel_delete', {id: materiel.id}) }}" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('materiel_delete_' ~ materiel.id) }}">
            <button type="submit"
                    data-confirm="Supprimer définitivement ce matériel ?"
                    class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm hover:bg-red-700 transition-colors">
                <i class="fas fa-trash mr-1"></i> Supprimer
            </button>
        </form>
    </div>
    {% endif %}

</div>
{% endblock %}
