{% extends 'base.html.twig' %}
{% block title %}{{ materiel.nom }} — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Matériels › Détail</div>

<div class="page-header">
    <div>
        <div class="page-title">{{ materiel.nom }}</div>
        <div class="page-sub">{{ materiel.categorie.nom }} — {{ materiel.localisation ?? 'Localisation inconnue' }}</div>
    </div>
    <div class="page-header-actions">
        {% if is_manager %}
        <a href="{{ path('materiel_edit', {id: materiel.id}) }}" class="btn btn-outline"><i class="fa-solid fa-pen"></i> Modifier</a>
        {% endif %}
        <a href="{{ path('materiel_index') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
    </div>
</div>

<div class="form-grid-2-16">

    <div class="table-wrap panel-padded-20">
        <div class="panel-title form-section-title-16">Informations</div>
        <table>
            <tbody>
                <tr><td class="td-label">N° Série</td><td>{{ materiel.numeroSerie ?? '—' }}</td></tr>
                <tr><td class="td-label">État</td><td><span class="sbadge {{ materiel.etat.badgeClass() }}">{{ materiel.etat.label() }}</span></td></tr>
                <tr><td class="td-label">Disponibilité</td>
                    <td>
                        {% if materiel.disponible %}
                            <span class="sbadge sb-success">Disponible</span>
                        {% else %}
                            <span class="sbadge sb-danger">Indisponible</span>
                        {% endif %}
                    </td>
                </tr>
                <tr><td class="td-label">Localisation</td><td>{{ materiel.localisation ?? '—' }}</td></tr>
                <tr><td class="td-label">Ajouté le</td><td>{{ materiel.createdAt|date('d/m/Y') }}</td></tr>
            </tbody>
        </table>
    </div>

    {% if is_manager %}
    <div class="table-wrap panel-padded-20">
        <div class="panel-title form-section-title-16">Ajouter un document</div>
        <form method="POST" action="{{ path('materiel_document_add', {id: materiel.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('add_doc' ~ materiel.id) }}">
            <div class="form-col-sm">
                <input type="text" name="titre" placeholder="Titre du document" class="form-control" required>
                <input type="text" name="url" placeholder="URL ou chemin du fichier" class="form-control" required>
                <select name="type" class="form-control">
                    <option value="notice">Notice</option>
                    <option value="doc_technique">Doc technique</option>
                    <option value="video">Vidéo</option>
                </select>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Ajouter</button>
            </div>
        </form>
    </div>
    {% endif %}

</div>

<div class="table-wrap">
    <div class="table-toolbar">
        <span class="panel-title">Documents ({{ materiel.documents|length }})</span>
    </div>
    <table>
        <thead>
            <tr><th>Titre</th><th>Type</th><th>URL</th><th>Actions</th></tr>
        </thead>
        <tbody>
            {% for doc in materiel.documents %}
            <tr>
                <td class="td-bold">{{ doc.titre }}</td>
                <td><span class="sbadge {{ doc.type.badgeClass() }}">{{ doc.type.label() }}</span></td>
                <td class="td-muted-url">{{ doc.url }}</td>
                <td>
                    {% if is_manager %}
                    <form method="POST" action="{{ path('materiel_document_delete', {id: doc.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('del_doc' ~ doc.id) }}">
                        <button type="submit" class="action-btn"><i class="fa-solid fa-trash"></i></button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% else %}
            <tr><td colspan="4" class="td-empty-sm">Aucun document</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if materiel.accessoires is not empty %}
<div class="table-wrap">
    <div class="table-toolbar">
        <span class="panel-title">Accessoires compatibles ({{ materiel.accessoires|length }})</span>
    </div>
    <table>
        <thead>
            <tr><th>Accessoire</th><th>État</th><th>Disponibilité</th></tr>
        </thead>
        <tbody>
            {% for acc in materiel.accessoires %}
            <tr>
                <td class="td-bold">
                    <a href="{{ path('materiel_show', {id: acc.id}) }}" class="link-inherit">{{ acc.nom }}</a>
                </td>
                <td><span class="sbadge {{ acc.etat.badgeClass() }}">{{ acc.etat.label() }}</span></td>
                <td>
                    {% if acc.disponible %}
                        <span class="sbadge sb-success"><i class="fa-solid fa-circle-check"></i> Disponible</span>
                    {% else %}
                        <span class="sbadge sb-danger"><i class="fa-solid fa-circle-xmark"></i> Indisponible</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{% if is_manager %}
<div class="table-wrap">
    <div class="table-toolbar">
        <span class="panel-title">Historique des emprunts</span>
    </div>
    <table>
        <thead>
            <tr><th>Utilisateur</th><th>Date début</th><th>Date fin prévue</th><th>Date retour</th><th>Statut</th></tr>
        </thead>
        <tbody>
            {% for e in materiel.emprunts %}
            <tr>
                <td class="td-bold">{{ e.utilisateur.nomComplet }}</td>
                <td>{{ e.dateDebut|date('d/m/Y') }}</td>
                <td>{{ e.dateFinPrevue|date('d/m/Y') }}</td>
                <td>{{ e.dateRetour ? e.dateRetour|date('d/m/Y') : '—' }}</td>
                <td><span class="sbadge {{ e.statut.badgeClass() }}">{{ e.statut.label() }}</span></td>
            </tr>
            {% else %}
            <tr><td colspan="5" class="td-empty-sm">Aucun emprunt</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
{% endblock %}
