{% extends 'base.html.twig' %}
{% block title %}Matériels — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Matériels</h1>
        <div class="flex gap-2">
            {% if isGestionnaire %}
            <a href="{{ path('materiel_export') }}"
               class="flex items-center gap-2 px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm hover:bg-gray-200 transition-colors">
                <i class="fas fa-download"></i> Export CSV
            </a>
            <a href="{{ path('materiel_new') }}"
               class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
                <i class="fas fa-plus"></i> Nouveau matériel
            </a>
            {% endif %}
        </div>
    </div>

    {# Filtres #}
    <form method="get" class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 mb-6 flex flex-wrap gap-3">
        <input type="text" name="search" value="{{ search }}" placeholder="Rechercher..."
               class="border border-gray-300 rounded-lg px-3 py-2 text-sm flex-1 min-w-48 focus:outline-none focus:border-primary">
        <select name="etat" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="">Tous les états</option>
            {% for e in etats %}
                <option value="{{ e.value }}" {{ etatFiltre == e.value ? 'selected' : '' }}>{{ e.label() }}</option>
            {% endfor %}
        </select>
        {% if isGestionnaire %}
        <select name="categorie" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
            <option value="">Toutes les catégories</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}" {{ catFiltre == cat.id ? 'selected' : '' }}>{{ cat.nom }}</option>
            {% endfor %}
        </select>
        {% endif %}
        <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
            <i class="fas fa-search"></i>
        </button>
        <a href="{{ path('materiel_index') }}" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm hover:bg-gray-200 transition-colors">
            <i class="fas fa-times"></i>
        </a>
    </form>

    {# Grille matériels #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {% for m in materiels %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="p-4">
                <div class="flex items-start justify-between mb-3">
                    <div class="w-10 h-10 bg-orange-50 rounded-lg flex items-center justify-center">
                        <i class="fas fa-laptop text-primary"></i>
                    </div>
                    <span class="text-xs px-2 py-1 rounded-full {{ m.etat.badgeClass() }}">{{ m.etat.label() }}</span>
                </div>
                <h3 class="font-semibold text-gray-800 text-sm mb-1 line-clamp-2">{{ m.nom }}</h3>
                <p class="text-xs text-gray-500 mb-1">{{ m.categorie.nom }}</p>
                {% if m.numeroSerie %}
                    <p class="text-xs text-gray-400 font-mono">{{ m.numeroSerie }}</p>
                {% endif %}
                {% if m.localisation %}
                    <p class="text-xs text-gray-400 mt-1"><i class="fas fa-map-marker-alt mr-1"></i>{{ m.localisation }}</p>
                {% endif %}
            </div>
            <div class="border-t border-gray-50 px-4 py-2 flex gap-2">
                <a href="{{ path('materiel_show', {id: m.id}) }}"
                   class="flex-1 text-center text-xs py-1.5 text-primary hover:bg-orange-50 rounded-lg transition-colors">
                    <i class="fas fa-eye mr-1"></i>Voir
                </a>
                {% if isGestionnaire %}
                <a href="{{ path('materiel_edit', {id: m.id}) }}"
                   class="flex-1 text-center text-xs py-1.5 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors">
                    <i class="fas fa-edit mr-1"></i>Modifier
                </a>
                {% endif %}
            </div>
        </div>
        {% else %}
        <div class="col-span-full py-16 text-center text-gray-400">
            <i class="fas fa-laptop text-4xl mb-3 block opacity-20"></i>
            Aucun matériel trouvé
        </div>
        {% endfor %}
    </div>

</div>
{% endblock %}
