<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Connexion — LOC MNS</title>
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('favicon.png') }}">
</head>
<body style="background:#F2F2F2;min-height:100vh;display:flex;align-items:center;justify-content:center;margin:0;font-family:system-ui,sans-serif;">

    <div style="background:white;width:100%;max-width:400px;border-radius:12px;padding:40px;box-shadow:0 2px 16px rgba(0,0,0,0.08);">

        <img src="{{ asset('images/loc.png') }}" alt="LOC MNS"
             style="height:60px;width:auto;display:block;margin:0 auto 24px;">

        <h1 style="text-align:center;font-size:22px;font-weight:700;color:#1A1A1A;margin:0 0 6px;">
            Connexion
        </h1>
        <p style="text-align:center;color:#888888;font-size:13px;margin:0 0 28px;">
            Accédez à votre espace LOC MNS
        </p>

        {% for message in app.flashes('error') %}
        <div style="background:#FEE2E2;color:#B91C1C;border-radius:6px;padding:10px 14px;font-size:13px;margin-bottom:16px;">
            {{ message }}
        </div>
        {% endfor %}

        <form method="POST" action="{{ path('login_check') }}" autocomplete="off">
            <input type="hidden" name="_token" value="{{ csrf_token('login') }}">

            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;">
                    Adresse email
                </label>
                <input type="email" name="email" required
                       autocomplete="off" autocorrect="off" autocapitalize="off"
                       style="width:100%;padding:10px 14px;border:1px solid #DDDDDD;border-radius:6px;font-size:14px;outline:none;box-sizing:border-box;transition:border-color .2s;"
                       onfocus="this.style.borderColor='#FF5C2C'"
                       onblur="this.style.borderColor='#DDDDDD'">
            </div>

            <div style="margin-bottom:24px;">
                <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;">
                    Mot de passe
                </label>
                <input type="password" name="password" required
                       autocomplete="new-password"
                       style="width:100%;padding:10px 14px;border:1px solid #DDDDDD;border-radius:6px;font-size:14px;outline:none;box-sizing:border-box;transition:border-color .2s;"
                       onfocus="this.style.borderColor='#FF5C2C'"
                       onblur="this.style.borderColor='#DDDDDD'">
            </div>

            <button type="submit"
                    style="width:100%;padding:12px;background:#FF5C2C;color:white;border:none;border-radius:6px;font-size:15px;font-weight:600;cursor:pointer;transition:background .2s;"
                    onmouseover="this.style.background='#e6512a'"
                    onmouseout="this.style.background='#FF5C2C'">
                Se connecter
            </button>
        </form>

    </div>

</body>
</html>
