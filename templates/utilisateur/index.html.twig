{% extends 'base.html.twig' %}
{% block title %}Utilisateurs — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Utilisateurs</div>

<div class="page-header">
    <div>
        <div class="page-title">Utilisateurs</div>
        <div class="page-sub">Gestion des comptes utilisateurs</div>
    </div>
    <div style="display:flex;gap:8px">
        <a href="{{ path('profil_index') }}" class="btn btn-outline"><i class="fa-solid fa-shield-halved"></i> Profils & Autorisations</a>
        <a href="{{ path('utilisateur_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouvel utilisateur</a>
    </div>
</div>

<div class="table-wrap">
<form method="GET" id="filter-utilisateurs">
    <div class="table-toolbar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" placeholder="Rechercher un utilisateur..." value="{{ filtre_search }}">
        </div>
        <div style="display:flex;gap:8px">
            <button type="submit" class="btn btn-outline"><i class="fa-solid fa-filter"></i> Filtrer</button>
        </div>
    </div>
</form>
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Email</th>
                <th>Profil</th>
                <th>Emprunts actifs</th>
                <th>Inscrit le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for u in utilisateurs %}
            <tr>
                <td class="td-muted">{{ u.id }}</td>
                <td class="td-bold">{{ u.nomComplet }}</td>
                <td class="td-muted">{{ u.email }}</td>
                <td>
                    <span class="sbadge sb-info">{{ u.profil.nom }}</span>
                    <span style="font-size:10px;color:#aaa;margin-left:4px">{{ u.profil.categories|length }} cat.</span>
                </td>
                <td>{{ u.empruntsActifs|length }}</td>
                <td class="td-muted">{{ u.createdAt|date('d/m/Y') }}</td>
                <td><div class="action-btns">
                    <a href="{{ path('utilisateur_edit', {id: u.id}) }}" class="action-btn" title="Modifier"><i class="fa-solid fa-pen"></i></a>
                    <form method="POST" action="{{ path('utilisateur_delete', {id: u.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_user' ~ u.id) }}">
                        <button type="submit" class="action-btn" title="Supprimer" onclick="return confirm('Supprimer cet utilisateur ?')"><i class="fa-solid fa-trash"></i></button>
                    </form>
                </div></td>
            </tr>
            {% else %}
            <tr><td colspan="7" style="text-align:center;padding:20px;color:#999">Aucun utilisateur trouvé</td></tr>
            {% endfor %}
        </tbody>
    </table>
    {% include '_pagination.html.twig' with {paginator: paginator} %}
</div>
{% endblock %}
