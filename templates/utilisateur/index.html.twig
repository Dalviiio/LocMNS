{% extends 'base.html.twig' %}
{% block title %}Utilisateurs — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Utilisateurs</h1>
        <a href="{{ path('utilisateur_new') }}"
           class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-orange-600 transition-colors">
            <i class="fas fa-plus"></i> Nouvel utilisateur
        </a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Nom</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Email</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Profil</th>
                    <th class="text-left px-4 py-3 text-gray-600 font-medium">Créé le</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                {% for u in utilisateurs %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-medium text-gray-800">{{ u.nomComplet }}</td>
                    <td class="px-4 py-3 text-gray-600">{{ u.email }}</td>
                    <td class="px-4 py-3">
                        <span class="text-xs bg-gray-100 text-gray-700 px-2 py-1 rounded-full">{{ u.profil.nom }}</span>
                    </td>
                    <td class="px-4 py-3 text-gray-500 text-xs">{{ u.createdAt|date('d/m/Y') }}</td>
                    <td class="px-4 py-3 flex gap-2 justify-end">
                        <a href="{{ path('utilisateur_edit', {id: u.id}) }}"
                           class="text-xs px-3 py-1 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 transition-colors">
                            <i class="fas fa-edit mr-1"></i>Modifier
                        </a>
                        <form action="{{ path('utilisateur_delete', {id: u.id}) }}" method="post" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('user_delete_' ~ u.id) }}">
                            <button type="submit" data-confirm="Supprimer cet utilisateur ?"
                                    class="text-xs px-3 py-1 bg-red-50 text-red-600 rounded hover:bg-red-100 transition-colors">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-4 py-10 text-center text-gray-400">Aucun utilisateur</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
