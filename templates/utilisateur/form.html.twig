{% extends 'base.html.twig' %}
{% block title %}{{ utilisateur ? 'Modifier' : 'Nouvel' }} utilisateur — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Utilisateurs › {{ utilisateur ? 'Modifier' : 'Nouveau' }}</div>

<div class="page-header">
    <div class="page-title">{{ utilisateur ? 'Modifier ' ~ utilisateur.nomComplet : 'Nouvel utilisateur' }}</div>
    <a href="{{ path('utilisateur_index') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
</div>

<div class="table-wrap form-wrap-md">
    <form method="POST" action="{{ utilisateur ? path('utilisateur_edit', {id: utilisateur.id}) : path('utilisateur_new') }}">
        <input type="hidden" name="_token" value="{{ csrf_token(utilisateur ? 'edit_user' ~ utilisateur.id : 'new_user') }}">
        <div class="form-grid-2">

            <div class="form-field">
                <label class="form-label">Prénom *</label>
                <input type="text" name="prenom" class="form-control" required value="{{ utilisateur ? utilisateur.prenom : '' }}">
            </div>

            <div class="form-field">
                <label class="form-label">Nom *</label>
                <input type="text" name="nom" class="form-control" required value="{{ utilisateur ? utilisateur.nom : '' }}">
            </div>

            <div class="form-field form-field-full">
                <label class="form-label">Email *</label>
                <input type="email" name="email" class="form-control" required value="{{ utilisateur ? utilisateur.email : '' }}">
            </div>

            <div class="form-field form-field-full">
                <label class="form-label">Mot de passe {{ utilisateur ? '(laisser vide pour ne pas changer)' : '*' }}</label>
                <input type="password" name="mot_de_passe" class="form-control" {{ utilisateur ? '' : 'required' }} autocomplete="new-password">
            </div>

            <div class="form-field form-field-full">
                <label class="form-label">Profil *</label>
                <select name="profil_id" class="form-control" required>
                    <option value="">-- Choisir --</option>
                    {% for p in profils %}
                    <option value="{{ p.id }}" {{ utilisateur and utilisateur.profil.id == p.id ? 'selected' : '' }}>{{ p.nom }}</option>
                    {% endfor %}
                </select>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
            <a href="{{ path('utilisateur_index') }}" class="btn btn-outline">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}
