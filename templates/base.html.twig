<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LOCMNS{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

<!-- ══ HEADER ══ -->
<header class="header">
    <div class="header-hamburger" id="hamburger">
        <i class="fa-solid fa-bars"></i>
    </div>
    <div class="header-logo">
        <div class="logo-box">
            <span class="loc">LOC</span><span class="mns">MNS</span>
        </div>
    </div>
    <div class="header-actions">
        <div class="h-btn"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <div class="h-btn"><i class="fa-solid fa-envelope"></i></div>
        <div class="h-btn"><i class="fa-solid fa-bell"></i></div>
        <div class="h-btn profile"><i class="fa-solid fa-circle-user"></i></div>
    </div>
</header>

<!-- ══ LAYOUT ══ -->
<div class="layout">

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" id="sidebar">
        <a href="{{ path('dashboard') }}"
           class="nav-item {% if app.request.attributes.get('_route') == 'dashboard' %}active{% endif %}"
           title="Dashboard">
            <i class="fa-solid fa-table-columns"></i>
        </a>
        <a href="{{ path('materiel_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'materiel' %}active{% endif %}"
           title="Matériels">
            <i class="fa-solid fa-box"></i>
        </a>
        <a href="{{ path('emprunt_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'emprunt' %}active{% endif %}"
           title="Emprunts">
            <i class="fa-solid fa-right-left"></i>
        </a>
        <a href="{{ path('reservation_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'reservation' %}active{% endif %}"
           title="Réservations">
            <i class="fa-solid fa-calendar-days"></i>
        </a>
        <a href="{{ path('alerte_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'alerte' %}active{% endif %}"
           title="Alertes">
            <i class="fa-solid fa-bell"></i>
        </a>
        <a href="{{ path('document_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'document' %}active{% endif %}"
           title="Documents">
            <i class="fa-solid fa-file-lines"></i>
        </a>
        <a href="{{ path('utilisateur_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'utilisateur' %}active{% endif %}"
           title="Utilisateurs">
            <i class="fa-solid fa-users"></i>
        </a>
    </aside>

    <!-- ══ MAIN ══ -->
    <main class="main">
        {% for msg in app.flashes('success') %}
            <div class="flash-success"><i class="fa-solid fa-circle-check"></i> {{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="flash-error"><i class="fa-solid fa-circle-xmark"></i> {{ msg }}</div>
        {% endfor %}
        {% block content %}{% endblock %}
    </main>

</div>

<script>
    document.getElementById('hamburger').addEventListener('click', function () {
        document.getElementById('sidebar').classList.toggle('open');
    });
</script>
</body>
</html>
