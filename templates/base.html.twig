<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LOC MNS{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#FF5C2C',
                        dark: '#1A1A1A',
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-100">

{# HEADER #}
<header class="fixed top-0 left-0 right-0 z-30 bg-dark text-white h-16 flex items-center px-4 shadow-lg">
    <button id="hamburger" class="md:hidden mr-3 text-gray-300 hover:text-white">
        <i class="fas fa-bars text-xl"></i>
    </button>
    <span class="text-2xl font-extrabold tracking-tight">
        <span class="text-primary">LOC</span><span class="text-white"> MNS</span>
    </span>
    <div class="flex-1"></div>
    <div class="flex items-center gap-4">
        {% set nbAlertes = app.session.get('nb_alertes', 0) %}
        <a href="{{ path('alerte_index') }}" class="relative text-gray-300 hover:text-white">
            <i class="fas fa-bell text-lg"></i>
            {% if nbAlertes > 0 %}
                <span class="absolute -top-1 -right-1 bg-primary text-white text-xs rounded-full w-4 h-4 flex items-center justify-center">{{ nbAlertes }}</span>
            {% endif %}
        </a>
        <div class="flex items-center gap-2 text-sm text-gray-300">
            <i class="fas fa-user-circle text-lg"></i>
            <span>{{ app.session.get('user_prenom') }} {{ app.session.get('user_nom') }}</span>
            <span class="text-xs bg-gray-700 px-2 py-0.5 rounded-full">{{ profilNom }}</span>
        </div>
        <form action="{{ path('logout') }}" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
            <button type="submit" class="text-gray-400 hover:text-red-400 ml-2" title="Déconnexion">
                <i class="fas fa-sign-out-alt"></i>
            </button>
        </form>
    </div>
</header>

{# SIDEBAR #}
<aside id="sidebar" class="fixed left-0 top-16 bottom-0 z-20 w-16 bg-gray-900 flex flex-col items-center py-4 gap-1 transform -translate-x-full md:translate-x-0 transition-transform duration-200">
    {% set currentRoute = app.request.attributes.get('_route') %}

    <a href="{{ path('dashboard') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'dashboard' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Tableau de bord">
        <i class="fas fa-tachometer-alt text-lg"></i>
    </a>

    <a href="{{ path('materiel_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'materiel' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Matériels">
        <i class="fas fa-laptop text-lg"></i>
    </a>

    <a href="{{ path('emprunt_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'emprunt' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Emprunts">
        <i class="fas fa-handshake text-lg"></i>
    </a>

    <a href="{{ path('reservation_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'reservation' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Réservations">
        <i class="fas fa-calendar-alt text-lg"></i>
    </a>

    <a href="{{ path('alerte_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'alerte' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Alertes">
        <i class="fas fa-exclamation-triangle text-lg"></i>
    </a>

    {% if isGestionnaire %}
    <a href="{{ path('document_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'document' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Documents">
        <i class="fas fa-file-alt text-lg"></i>
    </a>
    {% endif %}

    {% if isAdmin %}
    <div class="w-8 border-t border-gray-700 my-1"></div>
    <a href="{{ path('utilisateur_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'utilisateur' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Utilisateurs">
        <i class="fas fa-users text-lg"></i>
    </a>
    <a href="{{ path('profil_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'profil' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Profils">
        <i class="fas fa-id-card text-lg"></i>
    </a>
    {% endif %}

    <div class="flex-1"></div>
    <a href="{{ path('compte_index') }}"
       class="w-full flex flex-col items-center py-3 px-1 hover:text-primary hover:bg-gray-800 transition-colors {{ currentRoute starts with 'compte' ? 'text-primary border-l-2 border-primary bg-gray-800' : 'text-gray-400' }}"
       title="Mon compte">
        <i class="fas fa-cog text-lg"></i>
    </a>
</aside>

{# MAIN #}
<main class="md:ml-16 mt-16 p-6 min-h-screen">
    {% for msg in app.flashes('success') %}
        <div class="mb-4 px-4 py-3 rounded-lg bg-green-100 text-green-800 border border-green-200 flex items-center gap-2">
            <i class="fas fa-check-circle"></i> {{ msg }}
        </div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="mb-4 px-4 py-3 rounded-lg bg-red-100 text-red-800 border border-red-200 flex items-center gap-2">
            <i class="fas fa-times-circle"></i> {{ msg }}
        </div>
    {% endfor %}
    {% for msg in app.flashes('warning') %}
        <div class="mb-4 px-4 py-3 rounded-lg bg-yellow-100 text-yellow-800 border border-yellow-200 flex items-center gap-2">
            <i class="fas fa-exclamation-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {% block content %}{% endblock %}
</main>

<script src="{{ asset('js/app.js') }}"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
