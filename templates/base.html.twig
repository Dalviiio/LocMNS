<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LOCMNS{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('fonts/fa/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}?v=20260406b">
</head>
<body>

<!-- ══ HEADER ══ -->
<header class="header">
    <div class="header-hamburger" id="hamburger">
        <i class="fa-solid fa-bars"></i>
    </div>
    <div class="header-logo">
        <div class="logo-box">
            <span class="loc">LOC</span><span class="mns">MNS</span>
        </div>
    </div>
    <div class="header-actions">
        <a href="{{ path('alerte_index') }}" class="h-btn" title="Alertes" style="position:relative;text-decoration:none">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </a>
        <div class="h-btn h-dropdown-trigger" title="Notifications" id="notif-trigger" style="position:relative">
            <i class="fa-solid fa-bell"></i>
            <span id="notif-badge" style="display:none;position:absolute;top:4px;right:4px;width:8px;height:8px;border-radius:50%;background:var(--primary)"></span>
            <div class="h-dropdown h-notif-dropdown">
                <div class="h-dropdown-title">Dernières alertes</div>
                <div id="notif-list" style="max-height:280px;overflow-y:auto">
                    <div style="padding:20px;text-align:center;color:#aaa;font-size:12px">Chargement…</div>
                </div>
                <a href="{{ path('alerte_index') }}" class="h-dropdown-footer">Voir toutes les alertes →</a>
            </div>
        </div>
        <div class="h-btn h-dropdown-trigger" title="Mon compte" style="position:relative">
            <i class="fa-solid fa-circle-user"></i>
            <span style="font-size:12px;font-weight:600;margin-left:6px;display:none" id="h-username"></span>
            <div class="h-dropdown">
                <div class="h-dropdown-title">{{ app.session.get('user_nom') ?? 'Compte' }}</div>
                <div style="padding:4px 0">
                    <a href="{{ path('compte_index') }}" class="h-dropdown-item"><i class="fa-solid fa-user" style="width:16px"></i> Mon compte</a>
                    <a href="{{ path('utilisateur_index') }}" class="h-dropdown-item"><i class="fa-solid fa-users" style="width:16px"></i> Utilisateurs</a>
                    <div style="margin:6px 0;border-top:1px solid #F0F0F0"></div>
                    <a href="{{ path('logout') }}" class="h-dropdown-item" style="color:#FF5C2C"><i class="fa-solid fa-arrow-right-from-bracket" style="width:16px"></i> Déconnexion</a>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- ══ LAYOUT ══ -->
<div class="layout">

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" id="sidebar">
        <a href="{{ path('dashboard') }}"
           class="nav-item {% if app.request.attributes.get('_route') == 'dashboard' %}active{% endif %}"
           title="Dashboard">
            <i class="fa-solid fa-table-columns"></i>
        </a>
        <a href="{{ path('materiel_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'materiel' %}active{% endif %}"
           title="Matériels">
            <i class="fa-solid fa-box"></i>
        </a>
        <a href="{{ path('emprunt_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'emprunt' %}active{% endif %}"
           title="Emprunts">
            <i class="fa-solid fa-right-left"></i>
        </a>
        <a href="{{ path('reservation_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'reservation' %}active{% endif %}"
           title="Réservations">
            <i class="fa-solid fa-calendar-days"></i>
        </a>
        <a href="{{ path('alerte_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'alerte' %}active{% endif %}"
           title="Alertes">
            <i class="fa-solid fa-bell"></i>
        </a>
        <a href="{{ path('document_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'document' %}active{% endif %}"
           title="Documents">
            <i class="fa-solid fa-file-lines"></i>
        </a>
        <a href="{{ path('utilisateur_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'utilisateur' %}active{% endif %}"
           title="Utilisateurs">
            <i class="fa-solid fa-users"></i>
        </a>
    </aside>

    <!-- ══ MAIN ══ -->
    <main class="main">
        {% for msg in app.flashes('success') %}
            <div class="flash-success"><i class="fa-solid fa-circle-check"></i> {{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="flash-error"><i class="fa-solid fa-circle-xmark"></i> {{ msg }}</div>
        {% endfor %}
        {% block content %}{% endblock %}
    </main>

</div>

<script>
    document.getElementById('hamburger').addEventListener('click', function () {
        document.getElementById('sidebar').classList.toggle('open');
    });

    // Fermer les modals en cliquant l'arrière-plan
    document.querySelectorAll('[id^="modal-"]').forEach(function(modal) {
        modal.addEventListener('click', function(e) {
            if (e.target === modal) modal.style.display = 'none';
        });
    });

    // Dropdown notifications — chargement alertes
    var notifLoaded = false;
    document.querySelectorAll('.h-dropdown-trigger').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            btn.classList.toggle('open');
            if (btn.id === 'notif-trigger' && !notifLoaded) {
                notifLoaded = true;
                fetch('{{ path('alerte_api_dernieres') }}')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        var list = document.getElementById('notif-list');
                        if (data.total > 0) {
                            document.getElementById('notif-badge').style.display = 'block';
                        }
                        if (data.alertes.length === 0) {
                            list.innerHTML = '<div style="padding:20px;text-align:center;color:#aaa;font-size:12px">Aucune alerte non lue</div>';
                            return;
                        }
                        list.innerHTML = data.alertes.map(function(a) {
                            return '<div style="padding:12px 16px;border-bottom:1px solid #F5F5F5">' +
                                '<div style="display:flex;justify-content:space-between;margin-bottom:4px">' +
                                '<span class="sbadge ' + a.badge + '" style="font-size:9px">' + a.type + '</span>' +
                                '<span style="font-size:10px;color:#aaa">' + a.date + '</span>' +
                                '</div>' +
                                '<div style="font-size:12px;font-weight:600;color:#1A1A1A;margin-bottom:2px">' + a.message + '</div>' +
                                '<div style="font-size:11px;color:#999">' + a.user + '</div>' +
                                '</div>';
                        }).join('');
                    })
                    .catch(function() {
                        document.getElementById('notif-list').innerHTML = '<div style="padding:20px;text-align:center;color:#aaa;font-size:12px">Erreur de chargement</div>';
                    });
            }
        });
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('.h-dropdown-trigger.open').forEach(function(el) {
            el.classList.remove('open');
        });
    });
</script>
</body>
</html>
