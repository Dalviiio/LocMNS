<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}LOCMNS{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('images/loc.png') }}">
    <link rel="stylesheet" href="{{ asset('fonts/fa/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('css/app.css') }}?v=20260413b">
</head>
<body>

<!-- ══ HEADER ══ -->
<header class="header">
    <div class="header-hamburger" id="hamburger">
        <i class="fa-solid fa-bars"></i>
    </div>
    <div class="header-logo">
        <a href="{{ path('dashboard') }}" class="header-logo-link">
            <img src="{{ asset('images/loc.png') }}" alt="LOCMNS" class="header-logo-img">
        </a>
    </div>
    <div class="header-actions">
        {% if app.session.get('user_profil') in ['Administrateur', 'Gestionnaire'] %}
        <a href="{{ path('alerte_index') }}" class="h-btn h-dropdown-trigger" title="Alertes">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </a>
        <div class="h-btn h-dropdown-trigger" title="Notifications" id="notif-trigger">
            <i class="fa-solid fa-bell"></i>
            <span id="notif-badge" class="notif-dot"></span>
            <div class="h-dropdown h-notif-dropdown">
                <div class="h-dropdown-title">Dernières alertes</div>
                <div id="notif-list">
                    <div class="notif-loading">Chargement…</div>
                </div>
                <a href="{{ path('alerte_index') }}" class="h-dropdown-footer">Voir toutes les alertes →</a>
            </div>
        </div>
        {% endif %}
        <div class="h-btn h-dropdown-trigger" title="Mon compte">
            <i class="fa-solid fa-circle-user"></i>
            <div class="h-dropdown">
                <div class="h-dropdown-title">{{ app.session.get('user_nom') ?? 'Compte' }}</div>
                <div class="h-dropdown-menu-pad">
                    <a href="{{ path('compte_index') }}" class="h-dropdown-item"><i class="fa-solid fa-user h-dropdown-icon"></i> Mon compte</a>
                    {% if app.session.get('user_profil') == 'Administrateur' %}
                    <a href="{{ path('utilisateur_index') }}" class="h-dropdown-item"><i class="fa-solid fa-users h-dropdown-icon"></i> Utilisateurs</a>
                    {% endif %}
                    <div class="h-dropdown-divider"></div>
                    <a href="{{ path('logout') }}" class="h-dropdown-item h-dropdown-item-danger"><i class="fa-solid fa-arrow-right-from-bracket h-dropdown-icon"></i> Déconnexion</a>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- ══ LAYOUT ══ -->
<div class="layout">

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" id="sidebar">
        {# Dashboard — tous les profils #}
        <a href="{{ path('dashboard') }}"
           class="nav-item {% if app.request.attributes.get('_route') == 'dashboard' %}active{% endif %}"
           title="Dashboard">
            <i class="fa-solid fa-table-columns"></i>
        </a>

        {% if app.session.get('user_profil') in ['Administrateur', 'Gestionnaire'] %}
        {# Managers uniquement : Matériels, Emprunts, Réservations, Alertes #}
        <a href="{{ path('materiel_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'materiel' %}active{% endif %}"
           title="Matériels">
            <i class="fa-solid fa-box"></i>
        </a>
        <a href="{{ path('emprunt_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'emprunt' %}active{% endif %}"
           title="Emprunts">
            <i class="fa-solid fa-right-left"></i>
        </a>
        <a href="{{ path('reservation_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'reservation' %}active{% endif %}"
           title="Réservations">
            <i class="fa-solid fa-calendar-days"></i>
        </a>
        <a href="{{ path('alerte_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'alerte' %}active{% endif %}"
           title="Alertes">
            <i class="fa-solid fa-bell"></i>
        </a>
        <a href="{{ path('document_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'document' %}active{% endif %}"
           title="Documents">
            <i class="fa-solid fa-file-lines"></i>
        </a>
        {% else %}
        {# Employé / Stagiaire / Client : accès direct nouvelle réservation #}
        <a href="{{ path('reservation_new') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'reservation' %}active{% endif %}"
           title="Nouvelle réservation">
            <i class="fa-solid fa-calendar-plus"></i>
        </a>
        {% endif %}

        {% if app.session.get('user_profil') == 'Administrateur' %}
        <a href="{{ path('utilisateur_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'utilisateur' %}active{% endif %}"
           title="Utilisateurs">
            <i class="fa-solid fa-users"></i>
        </a>
        {% endif %}
    </aside>

    <!-- ══ MAIN ══ -->
    <main class="main">
        {% for msg in app.flashes('success') %}
            <div class="flash-success"><i class="fa-solid fa-circle-check"></i> {{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="flash-error"><i class="fa-solid fa-circle-xmark"></i> {{ msg }}</div>
        {% endfor %}
        {% block content %}{% endblock %}
    </main>

</div>

<script>
    document.getElementById('hamburger').addEventListener('click', function () {
        document.getElementById('sidebar').classList.toggle('open');
    });

    // Fermer les modals en cliquant l'arrière-plan
    document.querySelectorAll('[id^="modal-"]').forEach(function(modal) {
        modal.addEventListener('click', function(e) {
            if (e.target === modal) modal.style.display = 'none';
        });
    });

    // Dropdown notifications — chargement alertes
    var notifLoaded = false;
    document.querySelectorAll('.h-dropdown-trigger').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            btn.classList.toggle('open');
            if (btn.id === 'notif-trigger' && !notifLoaded) {
                notifLoaded = true;
                fetch('{{ path('alerte_api_dernieres') }}')
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        var list = document.getElementById('notif-list');
                        if (data.total > 0) {
                            document.getElementById('notif-badge').style.display = 'block';
                        }
                        if (data.alertes.length === 0) {
                            list.innerHTML = '<div class="notif-loading">Aucune alerte non lue</div>';
                            return;
                        }
                        list.innerHTML = data.alertes.map(function(a) {
                            return '<div class="h-notif-item">' +
                                '<div class="notif-meta">' +
                                '<span class="sbadge sbadge-xs ' + a.badge + '">' + a.type + '</span>' +
                                '<span class="notif-time">' + a.date + '</span>' +
                                '</div>' +
                                '<div class="h-notif-item-msg">' + a.message + '</div>' +
                                '<div class="h-notif-item-time">' + a.user + '</div>' +
                                '</div>';
                        }).join('');
                    })
                    .catch(function() {
                        document.getElementById('notif-list').innerHTML = '<div class="notif-loading">Erreur de chargement</div>';
                    });
            }
        });
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('.h-dropdown-trigger.open').forEach(function(el) {
            el.classList.remove('open');
        });
    });
</script>
</body>
</html>
