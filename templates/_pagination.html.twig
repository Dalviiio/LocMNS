{#
    Inclusion : {% include '_pagination.html.twig' with {paginator: paginator} %}
    Lit automatiquement la route courante et tous les query params existants.
#}
{% set route      = app.request.attributes.get('_route') %}
{% set baseParams = app.request.query.all|filter((v, k) => k != 'page' and k != 'per_page') %}

<div class="pagination-bar">
    {# Sélecteur par page #}
    <div class="pag-perpage">
        <span style="font-size:12px;color:var(--text-3)">Afficher</span>
        {% for n in [25, 50, 100, 200] %}
            {% if n == paginator.perPage %}
            <span class="pag-pp-active">{{ n }}</span>
            {% else %}
            <a href="{{ path(route, baseParams|merge({page: 1, per_page: n})) }}" class="pag-pp-btn">{{ n }}</a>
            {% endif %}
        {% endfor %}
        <span style="font-size:12px;color:var(--text-3)">/ {{ paginator.total }} résultat(s)</span>
    </div>

    {# Navigation pages #}
    {% if paginator.nbPages > 1 %}
    <div class="pag-nav">
        {# Précédent #}
        {% if paginator.hasPrev() %}
        <a href="{{ path(route, baseParams|merge({page: paginator.page - 1, per_page: paginator.perPage})) }}"
           class="pag-btn" title="Page précédente">
            <i class="fa-solid fa-chevron-left"></i>
        </a>
        {% else %}
        <span class="pag-btn pag-disabled"><i class="fa-solid fa-chevron-left"></i></span>
        {% endif %}

        {# Première page si éloignée #}
        {% if paginator.pages()[0] > 1 %}
        <a href="{{ path(route, baseParams|merge({page: 1, per_page: paginator.perPage})) }}" class="pag-btn">1</a>
        {% if paginator.pages()[0] > 2 %}
        <span class="pag-ellipsis">…</span>
        {% endif %}
        {% endif %}

        {# Pages centrales #}
        {% for p in paginator.pages() %}
            {% if p == paginator.page %}
            <span class="pag-btn pag-current">{{ p }}</span>
            {% else %}
            <a href="{{ path(route, baseParams|merge({page: p, per_page: paginator.perPage})) }}" class="pag-btn">{{ p }}</a>
            {% endif %}
        {% endfor %}

        {# Dernière page si éloignée #}
        {% if paginator.pages()[paginator.pages()|length - 1] < paginator.nbPages %}
        {% if paginator.pages()[paginator.pages()|length - 1] < paginator.nbPages - 1 %}
        <span class="pag-ellipsis">…</span>
        {% endif %}
        <a href="{{ path(route, baseParams|merge({page: paginator.nbPages, per_page: paginator.perPage})) }}" class="pag-btn">{{ paginator.nbPages }}</a>
        {% endif %}

        {# Suivant #}
        {% if paginator.hasNext() %}
        <a href="{{ path(route, baseParams|merge({page: paginator.page + 1, per_page: paginator.perPage})) }}"
           class="pag-btn" title="Page suivante">
            <i class="fa-solid fa-chevron-right"></i>
        </a>
        {% else %}
        <span class="pag-btn pag-disabled"><i class="fa-solid fa-chevron-right"></i></span>
        {% endif %}
    </div>
    {% endif %}
</div>
