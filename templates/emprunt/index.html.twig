{% extends 'base.html.twig' %}
{% block title %}Emprunts — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Emprunts</div>

<div class="page-header">
    <div>
        <div class="page-title">Emprunts</div>
        <div class="page-sub">Suivi des emprunts de matériel</div>
    </div>
    <div style="display:flex;gap:8px">
        <a href="{{ path('export_emprunts_csv') }}" class="btn btn-outline"><i class="fa-solid fa-download"></i> CSV</a>
        <a href="{{ path('emprunt_new') }}" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Nouvel emprunt</a>
    </div>
</div>

<div class="table-wrap">
<form method="GET">
    <div class="table-toolbar">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" name="search" placeholder="Rechercher..." value="{{ filtre_search }}">
        </div>
        <div style="display:flex;gap:8px">
            <select name="statut" class="form-select-sm" onchange="this.form.submit()">
                <option value="">Tous les statuts</option>
                {% for s in statuts %}
                <option value="{{ s.value }}" {{ filtre_statut == s.value ? 'selected' : '' }}>{{ s.label() }}</option>
                {% endfor %}
            </select>
            <button type="submit" class="btn btn-outline"><i class="fa-solid fa-filter"></i> Filtrer</button>
        </div>
    </div>
</form>
    <table>
        <thead>
            <tr>
                <th>#</th><th>Utilisateur</th><th>Matériel</th><th>Date début</th><th>Date fin prévue</th><th>Date retour</th><th>Statut</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for e in emprunts %}
            <tr>
                <td class="td-muted">{{ e.id }}</td>
                <td class="td-bold">{{ e.utilisateur.nomComplet }}</td>
                <td>{{ e.materiel.nom }}</td>
                <td>{{ e.dateDebut|date('d/m/Y') }}</td>
                <td>{{ e.dateFinPrevue|date('d/m/Y') }}</td>
                <td>{{ e.dateRetour ? e.dateRetour|date('d/m/Y') : '—' }}</td>
                <td><span class="sbadge {{ e.statut.badgeClass() }}">{{ e.statut.label() }}</span></td>
                <td><div class="action-btns">
                    <a href="{{ path('emprunt_show', {id: e.id}) }}" class="action-btn" title="Voir"><i class="fa-solid fa-eye"></i></a>
                    {% if e.statut.value == 'en_cours' or e.statut.value == 'retard' %}
                    <form method="POST" action="{{ path('emprunt_retour', {id: e.id}) }}" style="display:inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('retour_emprunt' ~ e.id) }}">
                        <button type="submit" class="action-btn" title="Enregistrer le retour"><i class="fa-solid fa-rotate-left"></i></button>
                    </form>
                    {% endif %}
                    <a href="{{ path('emprunt_edit', {id: e.id}) }}" class="action-btn" title="Modifier"><i class="fa-solid fa-pen"></i></a>
                </div></td>
            </tr>
            {% else %}
            <tr><td colspan="8" style="text-align:center;padding:20px;color:#999">Aucun emprunt trouvé</td></tr>
            {% endfor %}
        </tbody>
    </table>
    <div class="table-footer">
        <span>{{ emprunts|length }} résultat(s)</span>
    </div>
</div>
{% endblock %}
