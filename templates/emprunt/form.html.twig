{% extends 'base.html.twig' %}
{% block title %}{{ emprunt ? 'Modifier' : 'Nouvel' }} emprunt — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Emprunts › {{ emprunt ? 'Modifier' : 'Nouveau' }}</div>

<div class="page-header">
    <div class="page-title">{{ emprunt ? 'Modifier l\'emprunt #' ~ emprunt.id : 'Nouvel emprunt' }}</div>
    <a href="{{ path('emprunt_index') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
</div>

{% if acces_limite is defined and acces_limite %}
<div class="table-wrap form-wrap-sm">
    <div class="form-access-denied">
        <i class="fa-solid fa-lock"></i> Aucun matériel accessible avec votre profil.
    </div>
</div>

{% elseif is_manager %}
{# ══════════════════════════════════════════
   VUE GESTIONNAIRE — formulaire classique
══════════════════════════════════════════ #}
<div class="table-wrap form-wrap-md">
    <form method="POST" action="{{ emprunt ? path('emprunt_edit', {id: emprunt.id}) : path('emprunt_new') }}">
        <input type="hidden" name="_token" value="{{ csrf_token(emprunt ? 'edit_emprunt' ~ emprunt.id : 'new_emprunt') }}">
        <div class="form-grid-2">

            <div class="form-field">
                <label class="form-label">Utilisateur *</label>
                <select name="utilisateur_id" class="form-control" required>
                    <option value="">-- Choisir --</option>
                    {% for u in utilisateurs %}
                    <option value="{{ u.id }}" {{ emprunt and emprunt.utilisateur.id == u.id ? 'selected' : '' }}>{{ u.nomComplet }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-field">
                <label class="form-label">Matériel *</label>
                <select name="materiel_id" id="materiel_select" class="form-control" required>
                    <option value="">-- Choisir --</option>
                    {% for m in materiels %}
                    <option value="{{ m.id }}" {{ emprunt and emprunt.materiel.id == m.id ? 'selected' : '' }}>{{ m.nom }} — {{ m.categorie.nom }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-field">
                <label class="form-label">Date de début *</label>
                <input type="datetime-local" name="date_debut" class="form-control" required
                       value="{{ emprunt ? emprunt.dateDebut|date('Y-m-d\\TH:i') : '' }}">
            </div>

            <div class="form-field">
                <label class="form-label">Date de fin prévue *</label>
                <input type="datetime-local" name="date_fin_prevue" class="form-control" required
                       value="{{ emprunt ? emprunt.dateFinPrevue|date('Y-m-d\\TH:i') : '' }}">
            </div>

        </div>

        {% if not emprunt %}
        <div id="accessoires-wrap" class="accessoires-wrap">
            <div class="accessoires-section">
                <div class="accessoires-title">
                    <i class="fa-solid fa-paperclip accessoires-icon"></i>Accessoires disponibles
                </div>
                <div id="accessoires-list" class="accessoires-list">
                    <div class="td-muted">Sélectionnez un matériel pour voir ses accessoires</div>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Enregistrer</button>
            <a href="{{ path('emprunt_index') }}" class="btn btn-outline">Annuler</a>
        </div>
    </form>
</div>

{% else %}
{# ══════════════════════════════════════════
   VUE CLIENT — catalogue groupé
══════════════════════════════════════════ #}
<form method="POST" action="{{ path('emprunt_new') }}" id="form-client">
    <input type="hidden" name="_token" value="{{ csrf_token('new_emprunt') }}">
    <input type="hidden" name="utilisateur_id" value="{{ user_id_connecte }}">
    <input type="hidden" name="materiel_nom" id="materiel_nom_hidden" value="">

    {# Dates #}
    <div class="table-wrap form-wrap-600-mb">
        <div class="form-section-title form-section-title-16">Période d'emprunt</div>
        <div class="form-grid-2-16">
            <div class="form-field">
                <label class="form-label">Date de début *</label>
                <input type="datetime-local" name="date_debut" class="form-control" required>
            </div>
            <div class="form-field">
                <label class="form-label">Date de fin prévue *</label>
                <input type="datetime-local" name="date_fin_prevue" class="form-control" required>
            </div>
        </div>
    </div>

    {# Catalogue matériels #}
    <div class="table-wrap catalogue-wrap">
        <div class="catalogue-header">
            <div class="form-section-title-mb">Choisir un matériel</div>
            <div id="selection-info" class="selection-info">
                <span id="selection-nom" class="selection-nom"></span>
                <span id="selection-qty-label"></span>
            </div>
        </div>

        {% if catalogue_client is empty %}
        <div class="td-empty-24">Aucun matériel disponible.</div>
        {% else %}
        <div class="catalogue-grid">
            {% for item in catalogue_client %}
            <div class="cat-card-inner {% if item.dispo == 0 %}cat-card-inner--off{% endif %}"
                 data-nom="{{ item.nom }}"
                 data-dispo="{{ item.dispo }}"
                 onclick="selectCard(this)">

                {# Dot disponibilité #}
                <span class="cat-card-dot {{ item.dispo > 0 ? 'cat-card-dot--ok' : 'cat-card-dot--off' }}"></span>

                <div class="cat-card-name cat-card-name-pad {{ item.dispo == 0 ? 'cat-card-name--off' : '' }}">
                    {{ item.nom }}
                </div>
                <div class="cat-card-cat">{{ item.categorie }}</div>
                <div class="cat-card-avail">
                    <span class="{{ item.dispo > 0 ? 'cat-card-dispo--ok' : 'cat-card-dispo--off' }}">
                        {% if item.dispo > 0 %}{{ item.dispo }} dispo{% else %}Indisponible{% endif %}
                    </span>
                    <span class="cat-card-total">{{ item.total }} unité{{ item.total > 1 ? 's' : '' }}</span>
                </div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    {# Quantité + bouton submit #}
    <div class="table-wrap form-wrap-600 qty-panel" id="qty-panel">
        <div class="qty-panel-inner">
            <div class="qty-client-field">
                <label class="form-label">Quantité</label>
                <div class="qty-client-wrap">
                    <button type="button" onclick="changeQty(-1)" class="btn btn-outline qty-client-btn">−</button>
                    <input type="number" name="quantite" id="quantite" value="1" min="1" max="1"
                           class="qty-client-input">
                    <button type="button" onclick="changeQty(1)" class="btn btn-outline qty-client-btn">+</button>
                </div>
            </div>
            <div class="qty-spacer"></div>
            <button type="submit" class="btn btn-primary qty-client-submit" id="btn-submit" disabled>
                <i class="fa-solid fa-circle-check"></i> Créer l'emprunt
            </button>
        </div>
    </div>

</form>
{% endif %}

{% if is_manager and not emprunt %}
<script>
document.getElementById('materiel_select').addEventListener('change', function() {
    var id = this.value;
    var wrap = document.getElementById('accessoires-wrap');
    var list = document.getElementById('accessoires-list');
    if (!id) { wrap.style.display = 'none'; return; }
    fetch('/materiels/' + id + '/accessoires')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.length === 0) { wrap.style.display = 'none'; return; }
            wrap.style.display = 'block';
            list.innerHTML = data.map(function(a) {
                var dispo = a.disponible;
                var color = dispo ? '#22c55e' : '#ef4444';
                return '<label style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:#fff;border:1px solid #e5e5e5;border-radius:8px;cursor:' + (dispo ? 'pointer' : 'default') + '">' +
                    '<input type="checkbox" name="accessoire_ids[]" value="' + a.id + '" ' + (dispo ? '' : 'disabled') + ' style="accent-color:#FF5C2C;width:16px;height:16px">' +
                    '<span style="flex:1;font-size:13px;font-weight:600">' + a.nom + '</span>' +
                    '<span style="font-size:11px;color:#999">' + a.etat + '</span>' +
                    '<span style="font-size:11px;font-weight:600;color:' + color + '">' + (dispo ? 'Disponible' : 'Indisponible') + '</span>' +
                    '</label>';
            }).join('');
        });
});
</script>
{% endif %}

{% if not is_manager %}
<script>
var selectedDispo = 0;

function selectCard(el) {
    if (el.classList.contains('cat-card-inner--off')) return;

    document.querySelectorAll('.cat-card-inner').forEach(function(c) {
        c.classList.remove('cat-card-inner--selected');
    });

    el.classList.add('cat-card-inner--selected');

    var nom   = el.dataset.nom;
    var dispo = parseInt(el.dataset.dispo);
    selectedDispo = dispo;

    document.getElementById('materiel_nom_hidden').value = nom;

    var qtyInput = document.getElementById('quantite');
    qtyInput.max   = dispo;
    qtyInput.value = 1;

    document.getElementById('selection-nom').textContent = nom;
    document.getElementById('selection-info').style.display = 'block';
    document.getElementById('qty-panel').style.display = 'block';
    document.getElementById('btn-submit').disabled = false;
    updateQtyLabel();
}

function changeQty(delta) {
    var input = document.getElementById('quantite');
    var val   = parseInt(input.value) + delta;
    val = Math.max(1, Math.min(selectedDispo, val));
    input.value = val;
    updateQtyLabel();
}

function updateQtyLabel() {
    var val = document.getElementById('quantite').value;
    document.getElementById('selection-qty-label').textContent = ' — ' + val + ' unité' + (val > 1 ? 's' : '');
}

document.getElementById('quantite').addEventListener('input', updateQtyLabel);

document.getElementById('form-client').addEventListener('submit', function(e) {
    if (!document.getElementById('materiel_nom_hidden').value) {
        e.preventDefault();
        alert('Veuillez sélectionner un matériel.');
    }
});
</script>
{% endif %}

{% endblock %}
