{% extends 'base.html.twig' %}
{% block title %}Emprunt #{{ emprunt.id }} — LOC MNS{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('emprunt_index') }}" class="text-gray-400 hover:text-primary transition-colors">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h1 class="text-2xl font-bold text-gray-800">Emprunt #{{ emprunt.id }}</h1>
        <span class="text-sm px-3 py-1 rounded-full {{ emprunt.statut.badgeClass() }}">{{ emprunt.statut.label() }}</span>
        {% if emprunt.enRetard %}
            <span class="text-sm px-3 py-1 rounded-full bg-red-100 text-red-700 font-semibold">
                <i class="fas fa-clock mr-1"></i>En retard
            </span>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-info-circle text-primary"></i> Détails
            </h2>
            <dl class="space-y-3">
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Matériel</dt>
                    <dd class="text-sm font-medium text-gray-800">
                        <a href="{{ path('materiel_show', {id: emprunt.materiel.id}) }}" class="text-primary hover:underline">
                            {{ emprunt.materiel.nom }}
                        </a>
                    </dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Emprunteur</dt>
                    <dd class="text-sm text-gray-700">{{ emprunt.utilisateur.nomComplet }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Début</dt>
                    <dd class="text-sm text-gray-700">{{ emprunt.dateDebut|date('d/m/Y H:i') }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Fin prévue</dt>
                    <dd class="text-sm {{ emprunt.enRetard ? 'text-red-600 font-semibold' : 'text-gray-700' }}">
                        {{ emprunt.dateFinPrevue|date('d/m/Y H:i') }}
                    </dd>
                </div>
                {% if emprunt.dateRetour %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Retour effectif</dt>
                    <dd class="text-sm text-green-600 font-medium">{{ emprunt.dateRetour|date('d/m/Y H:i') }}</dd>
                </div>
                {% endif %}
                {% if emprunt.notes %}
                <div>
                    <dt class="text-sm text-gray-500 mb-1">Notes</dt>
                    <dd class="text-sm text-gray-700 bg-gray-50 rounded p-2">{{ emprunt.notes }}</dd>
                </div>
                {% endif %}
            </dl>

            {% if emprunt.statut.value != 'Rendu' %}
            <div class="mt-5 pt-4 border-t border-gray-100">
                <form action="{{ path('emprunt_retour', {id: emprunt.id}) }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('emprunt_retour_' ~ emprunt.id) }}">
                    <button type="submit"
                            data-confirm="Confirmer le retour du matériel ?"
                            class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded-lg text-sm font-medium transition-colors">
                        <i class="fas fa-check mr-1"></i> Enregistrer le retour
                    </button>
                </form>
            </div>
            {% endif %}
        </div>

        {% if emprunt.empruntsAccessoires|length %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-puzzle-piece text-primary"></i> Accessoires empruntés
            </h2>
            <div class="space-y-2">
                {% for empAcc in emprunt.empruntsAccessoires %}
                <div class="flex items-center justify-between py-2 border-b border-gray-50 last:border-0">
                    <span class="text-sm text-gray-700">{{ empAcc.materiel.nom }}</span>
                    <span class="text-xs px-2 py-0.5 rounded-full {{ empAcc.statut.badgeClass() }}">{{ empAcc.statut.label() }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Signaler un événement #}
        {% if emprunt.statut.value != 'Rendu' %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-flag text-primary"></i> Signaler un événement
            </h2>
            <form action="{{ path('emprunt_evenement', {id: emprunt.id}) }}" method="post" class="space-y-3">
                <input type="hidden" name="_token" value="{{ csrf_token('emprunt_evt_' ~ emprunt.id) }}">
                <select name="type" required
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary">
                    <option value="">Type d'événement...</option>
                    {% for t in typeEvenements %}
                        <option value="{{ t.value }}">{{ t.label() }}</option>
                    {% endfor %}
                </select>
                <textarea name="description" rows="2" placeholder="Description (optionnelle)"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-primary resize-none"></textarea>
                <button type="submit" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white py-2 rounded-lg text-sm font-medium transition-colors">
                    <i class="fas fa-flag mr-1"></i> Signaler
                </button>
            </form>
        </div>
        {% endif %}

        {# Historique événements #}
        {% if emprunt.evenements|length %}
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
            <h2 class="font-semibold text-gray-700 mb-4 flex items-center gap-2">
                <i class="fas fa-history text-primary"></i> Événements ({{ emprunt.evenements|length }})
            </h2>
            <div class="space-y-3">
                {% for evt in emprunt.evenements %}
                <div class="flex items-start gap-3">
                    <div class="w-2 h-2 bg-primary rounded-full mt-1.5 flex-shrink-0"></div>
                    <div>
                        <p class="text-xs font-semibold text-gray-700">{{ evt.type.label() }}</p>
                        {% if evt.description %}<p class="text-xs text-gray-500 mt-0.5">{{ evt.description }}</p>{% endif %}
                        <p class="text-xs text-gray-400 mt-0.5">{{ evt.createdAt|date('d/m/Y H:i') }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

    </div>

</div>
{% endblock %}
