{% extends 'base.html.twig' %}
{% block title %}Emprunt #{{ emprunt.id }} — LOCMNS{% endblock %}
{% block content %}

<div class="page-label">Emprunts › Détail</div>

<div class="page-header">
    <div>
        <div class="page-title">Emprunt #{{ emprunt.id }}</div>
        <div class="page-sub">{{ emprunt.materiel.nom }} — {{ emprunt.utilisateur.nomComplet }}</div>
    </div>
    <div class="page-header-actions">
        {% if is_manager %}
        {% if emprunt.statut.value == 'en_cours' or emprunt.statut.value == 'retard' %}
        <form method="POST" action="{{ path('emprunt_retour', {id: emprunt.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('retour_emprunt' ~ emprunt.id) }}">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-rotate-left"></i> Enregistrer le retour</button>
        </form>
        {% endif %}
        {% endif %}
        <a href="{{ path('emprunt_index') }}" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Retour</a>
    </div>
</div>

<div class="form-grid-2-16">

    <div class="table-wrap panel-padded-20">
        <div class="panel-title form-section-title-mb">Informations</div>
        <table><tbody>
            <tr><td class="td-label">Utilisateur</td><td class="td-bold">{{ emprunt.utilisateur.nomComplet }}</td></tr>
            <tr><td class="td-label">Matériel</td><td>{{ emprunt.materiel.nom }}</td></tr>
            <tr><td class="td-label">Date début</td><td>{{ emprunt.dateDebut|date('d/m/Y H:i') }}</td></tr>
            <tr><td class="td-label">Date fin prévue</td><td>{{ emprunt.dateFinPrevue|date('d/m/Y H:i') }}</td></tr>
            <tr><td class="td-label">Date retour</td><td>{{ emprunt.dateRetour ? emprunt.dateRetour|date('d/m/Y H:i') : '—' }}</td></tr>
            <tr><td class="td-label">Statut</td><td><span class="sbadge {{ emprunt.enRetard ? 'sb-danger' : emprunt.statut.badgeClass() }}">{{ emprunt.enRetard ? 'Retard' : emprunt.statut.label() }}</span></td></tr>
        </tbody></table>
    </div>

    <div class="table-wrap panel-padded-20">
        <div class="panel-title form-section-title-mb">Signaler un événement</div>
        <form method="POST" action="{{ path('emprunt_evenement_add', {id: emprunt.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('evenement_emprunt' ~ emprunt.id) }}">
            <div class="form-col-sm">
                <select name="type" class="form-control">
                    {% for t in types_evenement %}
                    <option value="{{ t.value }}">{{ t.label() }}</option>
                    {% endfor %}
                </select>
                <textarea name="description" class="form-control" rows="3" placeholder="Description (optionnel)"></textarea>
                <input type="datetime-local" name="nouvelle_date_fin" class="form-control" placeholder="Nouvelle date de fin (prolongation)">
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-flag"></i> Signaler</button>
            </div>
        </form>
    </div>

</div>

{% if emprunts_accessoires is not empty %}
<div class="table-wrap">
    <div class="table-toolbar">
        <span class="panel-title">Accessoires partis avec ce matériel ({{ emprunts_accessoires|length }})</span>
    </div>
    <table>
        <thead>
            <tr><th>Accessoire</th><th>Statut</th><th>Date retour</th><th>Voir</th></tr>
        </thead>
        <tbody>
            {% for ea in emprunts_accessoires %}
            <tr>
                <td class="td-bold">{{ ea.materiel.nom }}</td>
                <td><span class="sbadge {{ ea.enRetard ? 'sb-danger' : ea.statut.badgeClass() }}">{{ ea.enRetard ? 'Retard' : ea.statut.label() }}</span></td>
                <td class="td-muted">{{ ea.dateRetour ? ea.dateRetour|date('d/m/Y') : '—' }}</td>
                <td><a href="{{ path('emprunt_show', {id: ea.id}) }}" class="action-btn" title="Voir"><i class="fa-solid fa-eye"></i></a></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

<div class="table-wrap">
    <div class="table-toolbar">
        <span class="panel-title">Événements ({{ emprunt.evenements|length }})</span>
    </div>
    <table>
        <thead>
            <tr><th>Type</th><th>Description</th><th>Date</th></tr>
        </thead>
        <tbody>
            {% for ev in emprunt.evenements %}
            <tr>
                <td><span class="sbadge {{ ev.type.badgeClass() }}">{{ ev.type.label() }}</span></td>
                <td>{{ ev.description ?? '—' }}</td>
                <td class="td-muted">{{ ev.createdAt|date('d/m/Y H:i') }}</td>
            </tr>
            {% else %}
            <tr><td colspan="3" class="td-empty-sm">Aucun événement</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
